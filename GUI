local function pickRandomSillySequence()
	local count = #SILLY_SEQUENCES
	if count == 0 then return nil, 0 end
	
	if count == 1 then
		return SILLY_SEQUENCES[1], 1
	end
	
	local index
	repeat
		index = math.random(1, count)
	until index ~= lastSillyIndex
	
	lastSillyIndex = index
	return SILLY_SEQUENCES[index], index
end

local function pickRandomSillyAction()
	-- Pick from SILLY_ACTIONS (KissMV, HeadpatMV, FriendlyJump)
	local count = #SILLY_ACTIONS
	if count == 0 then return nil, 0 end
	
	if count == 1 then
		return SILLY_ACTIONS[1], 1
	end
	
	local index
	repeat
		index = math.random(1, count)
	until index ~= lastActionIndex
	
	lastActionIndex = index
	return SILLY_ACTIONS[index], index
end

local function isVictimLookingAtFollower(targetRoot, targetHumanoid, rootPart)
	if not targetRoot or not rootPart then return false end

	local victimLookDir = targetRoot.CFrame.LookVector
	local toFollower = (rootPart.Position - targetRoot.Position).Unit
	local dotProduct = victimLookDir:Dot(toFollower)
	
	return dotProduct > 0.94
end

local function isVictimViewBlocked(targetRoot, rootPart)
	local direction = (rootPart.Position - targetRoot.Position).Unit
	local distance = (rootPart.Position - targetRoot.Position).Magnitude
	
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {targetRoot.Parent, player.Character}
	
	local result = Workspace:Raycast(targetRoot.Position, direction * distance, rayParams)
	return result ~= nil
end

-- Function: Find all clickable objects nearby
local function scanClickables(centerPos)
	local found = {}
	local overlapParams = OverlapParams.new()
	overlapParams.MaxParts = 100
	
	local partsInRadius = Workspace:GetPartBoundsInRadius(centerPos, CLICK_SEARCH_RADIUS, overlapParams)
	
	for _, part in ipairs(partsInRadius) do
		local obj = part:FindFirstChildWhichIsA("ProximityPrompt") or part:FindFirstChildWhichIsA("ClickDetector")
		if obj then
			table.insert(found, obj)
		end
	end
	return found
end

-- Function: Click a random object from the cache
local function clickRandomObject()
	if #clickablesCache == 0 then 
		if SILLY_ENABLED then
			debugPrint("[CLICK] No clickables in cache")
		end
		return false 
	end
	
	local target = clickablesCache[math.random(1, #clickablesCache)]
	local targetName = target.Parent and target.Parent.Name or "Unknown"
	clickablesCache = {}
	
	if SILLY_ENABLED then
		debugPrint("[CLICK] Attempting to click: " .. targetName)
	end
	
	local success = pcall(function()
		if target:IsA("ClickDetector") then
			target:Fire()
		elseif target:IsA("ProximityPrompt") then
			local holdTime = target.HoldDuration or 0
			if holdTime > 0 then
				target:InputHoldBegin()
				task.wait(holdTime + 0.05)
				target:InputHoldEnd()
			else
				target:InputHoldBegin()
				task.wait(0.05)
				target:InputHoldEnd()
			end
		end
	end)
	
	if SILLY_ENABLED then
		if success then
			debugPrint("[CLICK] Successfully clicked: " .. targetName)
		else
			debugPrint("[CLICK] Failed to click: " .. targetName)
		end
	end
	
	return success
end

-- NEW Simple function: Check if someone is between follower and victim
local function isSomeoneBlocking(rootPart, targetRoot)
	local direction = (targetRoot.Position - rootPart.Position).Unit
	local distance = (targetRoot.Position - rootPart.Position).Magnitude
	
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player and otherPlayer ~= targetPlayer and otherPlayer.Character then
			local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
			if otherRoot then
				local toOther = otherRoot.Position - rootPart.Position
				local dot = toOther:Dot(direction)
				if dot > 0 and dot < distance then
					local projection = rootPart.Position + direction * dot
					local distFromLine = (otherRoot.Position - projection).Magnitude
					if distFromLine < 3 then
						return true, otherPlayer
					end
				end
			end
		end
	end
	return false, nil
end

