FollowButton.MouseButton1Click:Connect(function()
	local searchText = SearchBar.Text
	if searchText == "" then
		Status.Text = "Enter a name"
		Status.TextColor3 = Color3.fromRGB(255, 200, 100)
		return
	end
	local found = findPlayer(searchText)
	if found then
		print("[FOLLOW] Found player:", found.Name)
		stopFollowing()
		targetPlayer = found
		isFollowing = true
		startFollowing()
		Status.Text = "Following " .. found.DisplayName
		Status.TextColor3 = Color3.fromRGB(100, 200, 255)
		SearchBar.Text = found.Name
	else
		print("[FOLLOW] Player not found:", searchText)
		Status.Text = "Not found"
		Status.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
end)

