--  Main follow loop
-- ══════════════════════════════════════════════
local function startFollowing()
	if followConnection then followConnection:Disconnect() end

	local lastPathUpdate = 0
	local currentPath = nil
	local currentWaypointIndex = 0
	local lastPathTarget = nil

	victimIsMoving = false
	victimStillTimer = 0
	sillyCooldownEnd = 0
	sillyActive = false
	victimHasMovedSinceStart = false
	sillyJustCompleted = false
	inSideStand = false
	previousDistance = 0
	currentSillySequence = nil
	sillyLastPosition = nil
	sillyStuckTimer = 0
	
	shiftTested = false
	testPhase = 0
	testSamples = {}
	shiftIsSprint = true
	shiftTapDone = false

	print("============================================")
	print("[START] Following: " .. targetPlayer.Name)
	print("[START] EXIT_DISTANCE: " .. EXIT_DISTANCE .. " studs")
	print("[START] ENTER_DISTANCE: " .. ENTER_DISTANCE .. " studs")
	print("[START] Silly sequences loaded: " .. #SILLY_SEQUENCES)
	print("============================================")

	followConnection = RunService.RenderStepped:Connect(function(deltaTime)
		pruneSafetyCache()

		if not isFollowing or not targetPlayer or not targetPlayer.Parent then
			if targetPlayer and not targetPlayer.Parent then
				print("[STOP] Target left")
				stopFollowing()
				Status.Text = "Target left"
			end
			return
		end

		local character = player.Character
		local targetChar = targetPlayer.Character
		if not character or not targetChar then return end

		local humanoid = character:FindFirstChild("Humanoid")
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
		if not humanoid or not rootPart or not targetRoot then return end

		local followerSeated = isFollowerSeated()
		local targetSeated = isVictimSeated(targetHumanoid)
		
		if followerSeated and not targetSeated then
			humanoid.Sit = false
			humanoid.Jump = true
			debugPrint("[ANTI-SEAT] Forcing exit from seat")
			Status.Text = "Getting off seat"
		end

				-- ===== VEHICLE FOLLOW: Enter seat when victim is seated =====
		if VEHICLE_FOLLOW_ENABLED and targetSeated and not followerSeated and not sillyActive then
			local now = tick()
			
			-- Only check every 2 seconds to avoid spam
			if now - lastVehicleScan > 2 then
				lastVehicleScan = now
				
				-- Find nearby seats with ANY type of interaction
				local nearbySeats = {}
				for _, obj in ipairs(Workspace:GetDescendants()) do
					if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
						local parent = obj.Parent
						if parent and parent:IsA("BasePart") then
							local dist = (parent.Position - rootPart.Position).Magnitude
							if dist <= VEHICLE_SEARCH_RADIUS then
								-- Check if it's a seat
								local isSeat = parent:IsA("Seat") or parent:IsA("VehicleSeat") or parent.Name:lower():find("seat")
								if isSeat and obj.Enabled then
									-- Check if seat is NOT occupied (skip if victim is in it)
									local seatOccupied = false
									if parent:IsA("Seat") or parent:IsA("VehicleSeat") then
										seatOccupied = (parent.Occupant ~= nil)
									end
									if not seatOccupied then
										table.insert(nearbySeats, {
											object = obj,
											distance = dist,
											part = parent
										})
									end
								end
							end
						end
					end
				end
				
				if #nearbySeats > 0 then
					-- Sort by distance (closest first)
					table.sort(nearbySeats, function(a, b)
						return a.distance < b.distance
					end)
					
					local targetSeat = nearbySeats[1]
					local seatType = targetSeat.object:IsA("ProximityPrompt") and "ProximityPrompt" or "ClickDetector"
					
					local delay = math.random(VEHICLE_SEAT_DELAY_MIN * 10, VEHICLE_SEAT_DELAY_MAX * 10) / 10
					debugPrint("[VEHICLE] Found " .. seatType .. " seat! Entering in " .. string.format("%.1f", delay) .. "s")
					task.wait(delay)
					
					if targetSeat and targetSeat.object.Enabled and targetSeated and not followerSeated then
						local success = pcall(function()
							if targetSeat.object:IsA("ClickDetector") then
								targetSeat.object:Fire()
								debugPrint("[VEHICLE] Clicked passenger seat!")
							elseif targetSeat.object:IsA("ProximityPrompt") then
								local holdTime = targetSeat.object.HoldDuration or 0
								if holdTime > 0 then
									targetSeat.object:InputHoldBegin()
									task.wait(holdTime + 0.05)
									targetSeat.object:InputHoldEnd()
								else
									targetSeat.object:InputHoldBegin()
									task.wait(0.05)
									targetSeat.object:InputHoldEnd()
								end
								debugPrint("[VEHICLE] Entered driver seat!")
							end
						end)
						
						if success then
							debugPrint("[VEHICLE] Successfully entered vehicle!")
							isInVehicle = true
						else
							debugPrint("[VEHICLE] Failed to enter seat")
						end
					end
				else
					debugPrint("[VEHICLE] Victim seated but no available seats found nearby")
				end
			end
		end

		-- Reset vehicle state when victim gets out
		if not targetSeated and isInVehicle then
			isInVehicle = false
			vehicleSeatPrompt = nil
			debugPrint("[VEHICLE] Victim exited vehicle")
		end

		local distance = (targetRoot.Position - rootPart.Position).Magnitude
		local now = tick()

		if distance > EXIT_DISTANCE and previousDistance <= EXIT_DISTANCE then
			debugPrint("[RADIUS] EXITED 8 stud radius - Distance: " .. math.floor(distance) .. " studs")
		elseif distance <= ENTER_DISTANCE and previousDistance > ENTER_DISTANCE then
			debugPrint("[RADIUS] ENTERED 8 stud radius - Distance: " .. math.floor(distance) .. " studs")
		end
		previousDistance = distance
		
		updateSprintTest(character)

		-- ===== CAMERA TRACKING =====
		if CAMERA_ENABLED and targetRoot then
			local camera = workspace.CurrentCamera
			if camera then
				local mouseDelta = UserInputService:GetMouseDelta()
				local isManualCamera = (math.abs(mouseDelta.X) > 0 or math.abs(mouseDelta.Y) > 0)
				
				if isManualCamera then
					lastManualCameraTime = now
				end
				
				if distance > CAMERA_TRACK_MIN and distance <= CAMERA_TRACK_MAX then
					if lastManualCameraTime and (now - lastManualCameraTime) >= 0.5 then
						local lookAtPos = targetRoot.Position + Vector3.new(0, 2, 0)
						local newCFrame = CFrame.lookAt(camera.CFrame.Position, lookAtPos)
						camera.CFrame = camera.CFrame:Lerp(newCFrame, CAMERA_SMOOTHNESS)
					end
				end
			end
		end

		-- ===== STARING CONTEST =====
		if targetRoot and rootPart then
			local victimLooking = isVictimLookingAtFollower(targetRoot, targetHumanoid, rootPart)
			local now = tick()
			
			if victimLooking then
				if not staringActive and not stareDelayStart then
					stareDelayStart = now
					debugPrint("[STARE] Victim looking! Waiting 0.8s...")
				elseif staringActive then
					stareEndTime = now + 0.5
				end
			else
				if staringActive then
					if now >= stareEndTime then
						staringActive = false
						stareDelayStart = nil
						debugPrint("[STARE] Victim looked away")
					end
				elseif stareDelayStart then
					stareDelayStart = nil
					debugPrint("[STARE] Victim looked away during delay")
				end
			end
			
			if stareDelayStart and not staringActive then
				if now - stareDelayStart >= 0.8 then
					staringActive = true
					stareEndTime = now + 0.5
					stareDelayStart = nil
					debugPrint("[STARE] Now staring at victim!")
				end
			end
			
			if staringActive then
				local camera = workspace.CurrentCamera
				if camera then
					local lookAtPos = targetRoot.Position + Vector3.new(0, 2, 0)
					local newCFrame = CFrame.lookAt(camera.CFrame.Position, lookAtPos)
					camera.CFrame = camera.CFrame:Lerp(newCFrame, 0.08)
				end
				
				local flatDir = Vector3.new(targetRoot.Position.X - rootPart.Position.X, 0, targetRoot.Position.Z - rootPart.Position.Z)
				if flatDir.Magnitude > 0.1 then
					local targetCFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + flatDir.Unit)
					rootPart.CFrame = rootPart.CFrame:Lerp(targetCFrame, 0.15)
				end
			end
		end

		local wasMoving = victimIsMoving
		if targetHumanoid then
			if isVictimSeated(targetHumanoid) then
				victimIsMoving = false
			else
				local moveDir = targetHumanoid.MoveDirection.Magnitude
				local vel = targetRoot.AssemblyLinearVelocity.Magnitude
				victimIsMoving = (moveDir > 0.5) or (vel > 2)
				if wasMoving ~= victimIsMoving then
					debugPrint("[VICTIM]", victimIsMoving and "Started moving" or "Stopped moving")
				end
			end
			if victimIsMoving then
				victimHasMovedSinceStart = true
				sillyJustCompleted = false
				lastVictimPromptScan = 0 
			end
			
			if not victimHasMovedSinceStart and distance <= ENTER_DISTANCE then
				victimHasMovedSinceStart = true
			end
		else
			victimIsMoving = false
		end

		if now - lastStatusUpdate > 0.2 then
			lastStatusUpdate = now
			local silly = sillyActive and " [SILLY]" or ""
			local cam = (CAMERA_ENABLED and distance > CAMERA_TRACK_MIN and distance <= CAMERA_TRACK_MAX) and " [CAM]" or ""
			Status.Text = string.format("%s%s%s (%.0f)", targetPlayer.DisplayName, silly, cam, distance)
			Status.TextColor3 = Color3.fromRGB(100, 200, 255)
		end

		if not sillyActive and not isFollowerSeated() and SILLY_ENABLED and now >= sillyCooldownEnd then
			if not victimIsMoving and distance <= EXIT_DISTANCE and distance < MAX_SILLY_DISTANCE then
				victimStillTimer = victimStillTimer + deltaTime
				if math.floor(victimStillTimer) > math.floor(victimStillTimer - deltaTime) then
					debugPrint("[TIMER] Still:", math.floor(victimStillTimer), "/", VICTIM_STILL_TIME)
				end
				if victimStillTimer >= VICTIM_STILL_TIME then
					currentSillySequence, seqIndex = pickRandomSillySequence()
					if currentSillySequence then
						debugPrint("[SILLY] TRIGGERED! Playing Movement #" .. seqIndex)
						sillyActive = true
						sillyIndex = 1
						sillyJumped = false
						sillyLastPosition = nil
						sillyStuckTimer = 0
						victimStillTimer = 0
						sillyCooldownEnd = now + SILLY_COOLDOWN_TIME
						inSideStand = false
					else
						debugPrint("[SILLY] No movements available!")
						victimStillTimer = 0
					end
				end
			else
				if victimStillTimer > 0.5 then
					debugPrint("[TIMER] Reset - " .. (victimIsMoving and "moved" or "outside 8 studs"))
				end
				victimStillTimer = 0
			end
		else
			if victimStillTimer > 0.5 and victimIsMoving then
				debugPrint("[TIMER] Reset - moved")
			end
			victimStillTimer = 0
		end

				-- ===== INSTANT CLICK ON VICTIM'S PROMPTS (with 0.5s delay) =====
		if RANDOM_CLICK_ENABLED and targetRoot and not sillyActive then
			local now = tick()
			if now - lastVictimPromptScan > 1 then  -- Scan every second
				lastVictimPromptScan = now
				
				-- Scan victim's character for prompts/click detectors
				for _, obj in ipairs(targetChar:GetDescendants()) do
					if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
						local parent = obj.Parent
						if parent and parent:IsA("BasePart") then
							local dist = (parent.Position - rootPart.Position).Magnitude
							if dist <= 10 then  -- Within 10 studs
								debugPrint("[VICTIM CLICK] Found prompt on victim: " .. obj.Parent.Name .. " - clicking in 0.5s")
								
								-- Wait 0.5 seconds before clicking
								task.wait(0.5)
								
								-- Make sure we're still in range and victim still exists
								if not targetChar or not targetChar.Parent then return end
								local newDist = (parent.Position - rootPart.Position).Magnitude
								if newDist > 10 then
									debugPrint("[VICTIM CLICK] Victim moved too far, cancelling click")
									break
								end
								
								-- Click it!
								local success = pcall(function()
									if obj:IsA("ClickDetector") then
										obj:Fire()
										debugPrint("[VICTIM CLICK] Fired ClickDetector on victim!")
									elseif obj:IsA("ProximityPrompt") then
										local holdTime = obj.HoldDuration or 0
										if holdTime > 0 then
											obj:InputHoldBegin()
											task.wait(holdTime + 0.05)
											obj:InputHoldEnd()
										else
											obj:InputHoldBegin()
											task.wait(0.05)
											obj:InputHoldEnd()
										end
										debugPrint("[VICTIM CLICK] Triggered ProximityPrompt on victim!")
									end
								end)
								
								if success then
									-- Cancel silly mode after clicking victim
									if sillyActive then
										sillyActive = false
										currentSillySequence = nil
										debugPrint("[VICTIM CLICK] Cancelled silly mode")
									end
									victimStillTimer = 0
									sillyJustCompleted = true
									
									-- Reset click timers to prevent spam
									nextClickTime = 0
									lastVictimPromptScan = now + 5  -- Don't scan again for 5 seconds
									
									debugPrint("[VICTIM CLICK] Success! Disabled further prompts for 5s")
									break  -- Only click one thing per scan
								end
							end
						end
					end
				end
			end
		end

		-- ===== SILLY BEHAVIOR WITH STUCK DETECTION =====
		if sillyActive and currentSillySequence then
			if not sillyLastPosition then
				sillyLastPosition = rootPart.Position
				sillyStuckTimer = 0
			else
				local sillyMoved = (rootPart.Position - sillyLastPosition).Magnitude
				if sillyMoved < 0.5 then
					sillyStuckTimer = sillyStuckTimer + deltaTime
					if sillyStuckTimer >= 3 then
						debugPrint("[SILLY] Stuck detected! Canceling silly and forcing side-stand")
						
						sillyActive = false
						humanoid.Jump = false
						currentSillySequence = nil
						sillyLastPosition = nil
						
						inSideStand = true
						sideReached = false
						currentSide = (math.random(1, 2) == 1) and "left" or "right"
						local sidePos = getSidePosition(targetRoot, currentSide).Position
						if isSafePosition(sidePos) then
							sideTargetPosition = sidePos
						else
							local otherSide = (currentSide == "left") and "right" or "left"
							local altPos = getSidePosition(targetRoot, otherSide).Position
							sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
						end
						
						victimStillTimer = 0
						sillyJustCompleted = false
						
						debugPrint("[SILLY] Moving to side: " .. currentSide)
						return
					end
				else
					sillyStuckTimer = 0
					sillyLastPosition = rootPart.Position
				end
			end
			
			if sillyIndex <= #currentSillySequence then
				local data = currentSillySequence[sillyIndex]
				local movePos = targetRoot.Position + data[1]
				if isSafePosition(movePos) then
					smoothMove(humanoid, movePos)
				end
				if data[2] and not sillyJumped then
					debugPrint("[SILLY] Jump at index:", sillyIndex)
					humanoid.Jump = true
					sillyJumped = true
				elseif sillyJumped and humanoid.FloorMaterial ~= Enum.Material.Air then
					sillyJumped = false
				end
				local dist = (rootPart.Position - movePos).Magnitude
				if dist < (data[2] and 5 or 3) then
					sillyIndex = sillyIndex + 1
				end
			else
				debugPrint("[SILLY] Completed")
				sillyActive = false
				sillyJustCompleted = true
				humanoid.Jump = false
				inSideStand = false
				currentSide = nil
				sideTargetPosition = nil
				sideReached = false
				currentSillySequence = nil
				sillyLastPosition = nil
			end
			return
		end

		if inSideStand and distance > EXIT_DISTANCE then
			debugPrint("[SIDE] Exiting side-stand - exceeded 8 studs, chasing instantly")
			inSideStand = false
			currentSide = nil
			sideTargetPosition = nil
			sideReached = false
			nextClickTime = 0
		end

		if not inSideStand and not victimIsMoving and distance <= ENTER_DISTANCE and victimHasMovedSinceStart then
			if not sillyActive and victimStillTimer < 8 and not sillyJustCompleted then
				debugPrint("[SIDE] Entering side-stand (inside 8 studs, victim stopped)")
				inSideStand = true
				holdW(false)
				setSprint(false)
				sideReached = false
				currentSide = (math.random(1, 2) == 1) and "left" or "right"
				local sidePos = getSidePosition(targetRoot, currentSide).Position
				if isSafePosition(sidePos) then
					sideTargetPosition = sidePos
				else
					local otherSide = (currentSide == "left") and "right" or "left"
					local altPos = getSidePosition(targetRoot, otherSide).Position
					sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
				end
			end
		end

				if inSideStand and sideTargetPosition then
			if not sideReached then
				local distToSide = (rootPart.Position - sideTargetPosition).Magnitude
				if distToSide <= 2 then
					sideReached = true
					debugPrint("[SIDE] Reached side position")
				else
					smoothMove(humanoid, sideTargetPosition)
				end
			end
			
						-- ===== RANDOM CLICKING WHILE IN SIDE-STAND =====
			if sideReached and RANDOM_CLICK_ENABLED then
				local now = tick()
				
				-- Refresh clickables cache every 3 seconds
				if now - lastClickableScan > 3 then
					clickablesCache = scanClickables(rootPart.Position)
					lastClickableScan = now
					if #clickablesCache > 0 then
						debugPrint("[CLICK] Found " .. #clickablesCache .. " clickables nearby")
					else
						debugPrint("[CLICK] No clickables found within " .. CLICK_SEARCH_RADIUS .. " studs")
					end
				end
				
				-- Set next click time if not set
				if nextClickTime == 0 and #clickablesCache > 0 then
					local delay = math.random(MIN_CLICK_DELAY * 10, MAX_CLICK_DELAY * 10) / 10
					nextClickTime = now + delay
					debugPrint("[CLICK] Next click in " .. string.format("%.1f", delay) .. "s")
				end
				
				-- Time to click!
				if nextClickTime > 0 and now >= nextClickTime and #clickablesCache > 0 then
					local clickSuccess = clickRandomObject()
					
					if clickSuccess then
						-- Cancel silly mode after successful click
						if sillyActive then
							sillyActive = false
							currentSillySequence = nil
							debugPrint("[CLICK] Cancelled silly mode due to click")
						end
						
						-- Reset silly timers so it doesn't trigger while victim is still nearby
						victimStillTimer = 0
						sillyJustCompleted = true  -- Prevents silly from triggering until victim moves
						
						debugPrint("[CLICK] Disabled silly mode until victim moves away")
						
						-- Don't schedule another click - wait for victim to move
						nextClickTime = 0
					else
						-- Click failed, try again after delay
						local delay = math.random(MIN_CLICK_DELAY * 10, MAX_CLICK_DELAY * 10) / 10
						nextClickTime = now + delay
						debugPrint("[CLICK] Click failed, next attempt in " .. string.format("%.1f", delay) .. "s")
					end
				end
			end
			
			return
		else
			-- Reset click timer when leaving side-stand
			if nextClickTime ~= 0 then
				nextClickTime = 0
				debugPrint("[CLICK] Reset timer - left side-stand")
			end
		end

				-- ===== CHASE WHEN OUTSIDE 8 STUDS =====
		if distance > EXIT_DISTANCE then
			holdW(true)
			
			if distance >= SPRINT_DISTANCE and not shiftTested and testPhase == 0 and victimHasMovedSinceStart then
				testSprintBehavior(character)
			end
			
			if distance >= SPRINT_DISTANCE and shiftTested and shiftIsSprint then
				setSprint(true)
			elseif distance <= 10 then
				setSprint(false)
			end
			
			if distance < DIRECT_MOVE_DISTANCE then
				if isSafePosition(targetRoot.Position) then
					smoothMove(humanoid, targetRoot.Position)
				else
					smoothMove(humanoid, rootPart.Position)
				end
				currentPath = nil
				return
			end

									local needRecompute = false
			if not currentPath then
				needRecompute = true
				debugPrint("[PATH] Computing initial path")
			elseif lastPathTarget then
				local targetDrift = (targetRoot.Position - lastPathTarget).Magnitude
				if targetDrift > 50 then
					needRecompute = true
					debugPrint("[PATH] Recomputing - target moved " .. math.floor(targetDrift) .. " studs")
				elseif currentWaypointIndex > #currentPath:GetWaypoints() then
					if distance > DIRECT_MOVE_DISTANCE and (rootPart.Position - targetRoot.Position).Magnitude > 10 then
						needRecompute = true
						debugPrint("[PATH] Recomputing - reached end of path but still far")
					end
				end
			end
			
			if needRecompute and (now - lastPathUpdate) < 2.0 then
				needRecompute = false
			end

			if needRecompute then
				lastPathUpdate = now
				if isSafePosition(targetRoot.Position) then
					local path = PathfindingService:CreatePath({
						AgentRadius = 2,
						AgentHeight = 5,
						AgentCanJump = true,
						AgentJumpHeight = 7.5,
						AgentMaxSlope = 45,
						WaypointSpacing = 4,
					})
					local success = pcall(function()
						path:ComputeAsync(rootPart.Position, targetRoot.Position)
					end)
					if success and path.Status == Enum.PathStatus.Success then
						currentPath = path
						currentWaypointIndex = 1
						lastPathTarget = targetRoot.Position
						debugPrint("[PATH] Path computed successfully with " .. #path:GetWaypoints() .. " waypoints")
					else
						currentPath = nil
						debugPrint("[PATH] Path computation failed")
					end
				else
					currentPath = nil
				end
			end

			if currentPath then
				local waypoints = currentPath:GetWaypoints()
				
				while currentWaypointIndex <= #waypoints do
					local wp = waypoints[currentWaypointIndex]
					if (rootPart.Position - wp.Position).Magnitude < WAYPOINT_RADIUS then
						currentWaypointIndex = currentWaypointIndex + 1
					else
						break
					end
				end
				
				if currentWaypointIndex <= #waypoints then
					local waypoint = waypoints[currentWaypointIndex]
					if isSafePosition(waypoint.Position) then
						smoothMove(humanoid, waypoint.Position)
						if waypoint.Action == Enum.PathWaypointAction.Jump then
							humanoid.Jump = true
						end
					else
						currentWaypointIndex = currentWaypointIndex + 1
					end
				else
					if distance > DIRECT_MOVE_DISTANCE then
						currentPath = nil
					end
				end
			else
				if isSafePosition(targetRoot.Position) then
					smoothMove(humanoid, targetRoot.Position)
				else
					smoothMove(humanoid, rootPart.Position)
				end
			end
		end
		
		-- Release W when inside W_RELEASE_DISTANCE
		if distance <= W_RELEASE_DISTANCE then
			if not isSprinting then
				holdW(false)
			end
			pcall(function()
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
			end)
		end
	end)
end

