-- Timestamp function (HH:MM:SS.mmm)
local function getTimestamp()
	local now = os.time()
	local ms = math.floor((tick() % 1) * 1000)
	local hour = math.floor((now % 86400) / 3600)
	local minute = math.floor((now % 3600) / 60)
	local second = now % 60
	return string.format("%02d:%02d:%02d.%03d", hour, minute, second, ms)
end

-- Override print to capture EVERYTHING
local originalPrint = print
print = function(...)
	local args = {...}
	local msg = table.concat(args, " ")
	local timestamped = string.format("[%s] %s", getTimestamp(), msg)
	
	originalPrint(timestamped)
	
	if consoleLogs then
		pcall(function()
			table.insert(consoleLogs, timestamped)
		end)
	end
end

local function debugPrint(...)
	if DEBUG_ENABLED then
		local args = {...}
		local msg = table.concat(args, " ")
		local timestamped = string.format("[%s] [DEBUG] %s", getTimestamp(), msg)
		
		originalPrint(timestamped)
		
		if consoleLogs then
			pcall(function()
				table.insert(consoleLogs, timestamped)
			end)
		end
	end
end

