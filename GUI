--  Sprint System with Crouch Detection
-- ══════════════════════════════════════════════
local function holdW(enable)
	if enable == isHoldingW then return end
	isHoldingW = enable
	local success = pcall(function()
		VirtualInputManager:SendKeyEvent(enable, Enum.KeyCode.W, false, game)
	end)
	if DEBUG_ENABLED then
		print("[KEY] W " .. (enable and "DOWN" or "UP") .. " - Success: " .. tostring(success))
	end
end

local function setSprint(enable)
	if not SPRINT_ENABLED then return end
	if not shiftIsSprint then return end
	if enable == isSprinting then return end
	
	isSprinting = enable
	holdW(enable)
	local success = pcall(function()
		VirtualInputManager:SendKeyEvent(enable, Enum.KeyCode.LeftShift, false, game)
	end)
	if DEBUG_ENABLED then
		print("[KEY] Shift " .. (enable and "DOWN" or "UP") .. " - Success: " .. tostring(success))
	end
end

local function testSprintBehavior(character)
	if testPhase ~= 0 then return end
	if shiftTested then return end
	
	local humanoid = character:FindFirstChild("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return end
	if humanoid.FloorMaterial == Enum.Material.Air then return end
	
	testPhase = 1
	testSpeedBefore = rootPart.Velocity.Magnitude
	testStartTime = tick()
	
	print("[SPRINT TEST] Holding W + Shift - check if character speeds up!")
	holdW(true)
	pcall(function()
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
	end)
end

local function updateSprintTest(character)
	if testPhase == 0 then return end
	
	local humanoid = character:FindFirstChild("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then
		testPhase = 0
		return
	end
	
	local now = tick()
	
	if testPhase == 1 and (now - testStartTime) >= 1.5 then
		local speedAfter = rootPart.Velocity.Magnitude
		
		pcall(function()
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
		end)
		holdW(false)
		
		local result = "unknown"
		if speedAfter > testSpeedBefore + 0.5 then
			result = "sprint"
			table.insert(testSamples, "sprint")
		elseif speedAfter < testSpeedBefore - 0.5 then
			result = "crouch"
			table.insert(testSamples, "crouch")
		else
			result = "none"
			table.insert(testSamples, "none")
		end
		
		debugPrint("[SPRINT TEST] Sample " .. #testSamples .. ": " .. result)
		
		if #testSamples >= SHIFT_TEST_COUNT then
			shiftTested = true
			local sprintCount = 0
			local crouchCount = 0
			local noneCount = 0
			
			for _, v in ipairs(testSamples) do
				if v == "sprint" then sprintCount = sprintCount + 1
				elseif v == "crouch" then crouchCount = crouchCount + 1
				else noneCount = noneCount + 1
				end
			end
			
			if sprintCount >= SHIFT_TEST_COUNT / 2 then
				shiftIsSprint = true
				print("[SPRINT] Detection complete - SPRINT enabled")
			elseif crouchCount >= SHIFT_TEST_COUNT / 2 then
				shiftIsSprint = false
				if not shiftTapDone then
					shiftTapDone = true
					print("[SPRINT] Detection complete - CROUCH detected, tapping Shift once to stand up")
					task.wait(0.1)
					pcall(function()
						VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
						task.wait(0.05)
						VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
					end)
				end
			else
				shiftIsSprint = false
				if not shiftTapDone then
					shiftTapDone = true
					print("[SPRINT] Detection complete - NO sprint mechanics, tapping Shift once for Shift Lock")
					pcall(function()
						VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
						task.wait(0.05)
						VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
					end)
				end
			end
			testPhase = 0
		else
			testPhase = 0
		end
	end
end

