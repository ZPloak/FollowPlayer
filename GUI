-- ══════════════════════════════════════════════
--  Anti‑void: working raycast safety check
-- ══════════════════════════════════════════════
--  Rounds a position to a coarse grid so nearby points share a cache entry
--  and we don't raycast every single frame for the same spot.
local CACHE_GRID = 2  -- studs
local function cacheKey(pos)
	return math.floor(pos.X / CACHE_GRID) .. ","
		.. math.floor(pos.Y / CACHE_GRID) .. ","
		.. math.floor(pos.Z / CACHE_GRID)
end

--  Build a raycast params object that ignores the local character so we
--  don't accidentally hit our own parts.
local function makeRaycastParams()
	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	local char = player.Character
	if char then
		rp.FilterDescendantsInstances = { char }
	else
		rp.FilterDescendantsInstances = {}
	end
	return rp
end

--[[
	isSafePosition(pos)
	Returns true  → there is solid ground within SAFE_GROUND_MAX_DROP studs below pos.
	Returns false → the spot is over a void, a cliff, or an invisible kill‑brick gap.

	Cast origin is pos + (0, 3, 0) so we start slightly above the surface and
	don't false‑positive when the character is already standing on terrain.
--]]
local function isSafePosition(pos)
	if not USE_SAFETY_RAYCAST then return true end
	if not pos then return false end

	local key = cacheKey(pos)
	local now = tick()
	local cached = safetyCache[key]
	if cached and (now - cached.t) < SAFE_RAYCAST_CACHE_TIME then
		return cached.safe
	end

	local origin    = Vector3.new(pos.X, pos.Y + 3, pos.Z)
	local direction = Vector3.new(0, -(SAFE_GROUND_MAX_DROP + 3), 0)
	local rp        = makeRaycastParams()

	local result = Workspace:Raycast(origin, direction, rp)
	local safe   = result ~= nil  -- hit something = ground exists = safe

	safetyCache[key] = { safe = safe, t = now }
	return safe
end

-- Periodically prune old cache entries so it doesn't grow forever
local lastCachePrune = 0
local function pruneSafetyCache()
	local now = tick()
	if now - lastCachePrune < 5 then return end
	lastCachePrune = now
	for k, v in pairs(safetyCache) do
		if now - v.t > 10 then
			safetyCache[k] = nil
		end
	end
end

-- ══════════════════════════════════════════════
--  Movement helpers
-- ══════════════════════════════════════════════
local function smoothMove(humanoid, targetPos)
	if not targetPos or not humanoid then return end
	if lastMoveTarget and (targetPos - lastMoveTarget).Magnitude < MOVE_TOLERANCE then return end
	lastMoveTarget = targetPos
	pcall(function() humanoid:MoveTo(targetPos) end)
end

local function fallbackSmoothMove(humanoid, targetPos)
	if not targetPos or not humanoid then return end
	if fallbackLastMoveTarget and (targetPos - fallbackLastMoveTarget).Magnitude < FALLBACK_MOVE_TOLERANCE then return end
	fallbackLastMoveTarget = targetPos
	pcall(function() humanoid:MoveTo(targetPos) end)
end

-- ══════════════════════════════════════════════
--  Helpers
-- ══════════════════════════════════════════════
local function findPlayer(searchText)
	if searchText == "" then return nil end
	local searchLower = searchText:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			if p.Name:lower():find(searchLower, 1, true)
				or p.DisplayName:lower():find(searchLower, 1, true) then
				return p
			end
		end
	end
	return nil
end

local function getSidePosition(targetRoot, side)
	if side == "left" then
		return targetRoot.CFrame * CFrame.new(-SIDE_DISTANCE, 0, 0)
	elseif side == "right" then
		return targetRoot.CFrame * CFrame.new(SIDE_DISTANCE, 0, 0)
	end
	return targetRoot.Position
end

local function isSeated(humanoid)
	return humanoid and humanoid.SeatPart ~= nil
end

local function resetFallbackState()
	fallbackActive          = false
	fallbackPath            = nil
	fallbackTarget          = nil
	fallbackLastPathUpdate  = 0
	fallbackLastPathTarget  = nil
	fallbackLastMoveTarget  = nil
	fallbackWaypointIndex   = 1
	stuckTimer              = 0
	lastPosition            = nil
end

local function stopFollowing()
	isFollowing      = false
	targetPlayer     = nil
	wasInRadius      = false
	currentSide      = nil
	sideTargetPosition = nil
	sideReached      = false
	recordDelayEnd   = nil
	isReplaying      = false
	jumpTriggered    = false
	lastMoveTarget   = nil
	resetFallbackState()

	if recordedMode then
		recordedMode = false
		if recordConnection then recordConnection:Disconnect() end
		recordedPositions   = {}
		recordedJumpIndices = {}
		replayIndex         = 1
		RecordButton.Text   = "Enable Recorded Mode"
		Status.Text         = "Recorded mode disabled"
	end

	if followConnection then
		followConnection:Disconnect()
		followConnection = nil
	end

	local char = player.Character
	if char then
		local hum = char:FindFirstChild("Humanoid")
		if hum and hum.Parent and hum.Parent:FindFirstChild("HumanoidRootPart") then
			pcall(function() hum:MoveTo(hum.Parent.HumanoidRootPart.Position) end)
		end
	end

	Status.Text      = "Stopped"
	Status.TextColor3 = Color3.fromRGB(200, 200, 200)
end

local function startRecording()
	if recordConnection then recordConnection:Disconnect() end
	recordedPositions   = {}
	recordedJumpIndices = {}
	replayIndex         = 1
	recordDelayEnd      = nil
	isReplaying         = false
	jumpTriggered       = false

	local lastJumpState  = false
	local lastRecordTime = tick()

	recordConnection = RunService.RenderStepped:Connect(function()
		if not isFollowing or not targetPlayer or not targetPlayer.Character then return end
		local targetChar = targetPlayer.Character
		local localChar  = player.Character
		if not targetChar or not localChar then return end
		local targetRoot     = targetChar:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local localRoot      = localChar:FindFirstChild("HumanoidRootPart")
		if not targetRoot or not localRoot or not targetHumanoid then return end

		local distance = (targetRoot.Position - localRoot.Position).Magnitude
		if distance > STOP_DISTANCE then
			local now = tick()
			if now - lastRecordTime >= RECORD_INTERVAL then
				-- Only record positions that are safe so the replay path never
				-- includes cliff‑edge or void waypoints.
				local recPos = targetRoot.Position
				if isSafePosition(recPos) then
					table.insert(recordedPositions, recPos)
					local idx       = #recordedPositions
					local isJumping = targetHumanoid.Jump or (targetRoot.AssemblyLinearVelocity.Y > 5)
					if isJumping and not lastJumpState then
						recordedJumpIndices[idx] = true
					end
					lastJumpState = isJumping
				end
				lastRecordTime = now
			end
		end
	end)
end

local function toggleRecordedMode()
	if not isFollowing then
		Status.Text = "Start following first"
		return
	end
	recordedMode = not recordedMode
	if recordedMode then
		startRecording()
		RecordButton.Text  = "Disable Recorded Mode"
		Status.Text        = "Recording path"
		Status.TextColor3  = Color3.fromRGB(255, 200, 100)
	else
		if recordConnection then recordConnection:Disconnect() end
		recordedPositions   = {}
		recordedJumpIndices = {}
		replayIndex         = 1
		recordDelayEnd      = nil
		isReplaying         = false
		lastMoveTarget      = nil
		resetFallbackState()
		RecordButton.Text  = "Enable Recorded Mode"
		Status.Text        = "Recorded mode off"
		Status.TextColor3  = Color3.fromRGB(100, 200, 255)
	end
end

local function toggleAutoSwitch()
	autoSwitchEnabled = not autoSwitchEnabled
	AutoSwitchButton.Text = autoSwitchEnabled and "Auto‑Switcher: ON" or "Auto‑Switcher: OFF"
	if not autoSwitchEnabled then
		resetFallbackState()
	end
end

local function findNearestWaypointIndex(pos)
	if #recordedPositions == 0 then return 1 end
	local bestIdx  = 1
	local bestDist = (pos - recordedPositions[1]).Magnitude
	for i = 2, #recordedPositions do
		local d = (pos - recordedPositions[i]).Magnitude
		if d < bestDist then
			bestDist = d
			bestIdx  = i
		end
	end
	return bestIdx
end

-- ══════════════════════════════════════════════
--  Main follow loop
-- ══════════════════════════════════════════════
local function startFollowing()
	if followConnection then followConnection:Disconnect() end

	local lastPathUpdate       = 0
	local currentPath          = nil
	local currentWaypointIndex = 0
	local lastWasInside        = false
	local lastPathTarget       = nil
	local directMoveThreshold  = STOP_DISTANCE + 3
	local lastTargetPos        = nil

	followConnection = RunService.RenderStepped:Connect(function(deltaTime)
		pruneSafetyCache()

		if not isFollowing or not targetPlayer or not targetPlayer.Parent then
			if targetPlayer and not targetPlayer.Parent then
				stopFollowing()
				Status.Text = "Target left"
			end
			return
		end

		local character  = player.Character
		local targetChar = targetPlayer.Character
		if not character or not targetChar then return end

		local humanoid       = character:FindFirstChild("Humanoid")
		local rootPart       = character:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local targetRoot     = targetChar:FindFirstChild("HumanoidRootPart")
		if not humanoid or not rootPart or not targetRoot then return end

		-- Anti‑seat
		local followerSeated = isSeated(humanoid)
		local targetSeated   = targetHumanoid and isSeated(targetHumanoid)
		if followerSeated and not targetSeated then
			humanoid.Sit = false
			local now = tick()
			if now - lastSeatExitTime > 1.0 then
				humanoid.Jump    = true
				lastSeatExitTime = now
				Status.Text      = "Jumping off seat"
			end
			smoothMove(humanoid, rootPart.Position)
		end

		local distance = (targetRoot.Position - rootPart.Position).Magnitude
		local isInside = distance <= STOP_DISTANCE
		local now      = tick()

		-- Status label
		if now - lastStatusUpdate > 0.2 then
			lastStatusUpdate = now
			local mode = ""
			if recordedMode then
				if fallbackActive then mode = " [FALLBACK]"
				elseif isReplaying  then mode = " [REPLAY]"
				else                     mode = " [REC]"
				end
			end
			Status.Text      = string.format("%s%s (%.0f)", targetPlayer.DisplayName, mode, distance)
			Status.TextColor3 = recordedMode
				and Color3.fromRGB(255, 200, 100)
				or  Color3.fromRGB(100, 200, 255)
		end

		-- ── Side‑stand when inside stop radius ──────────────────────
		if isInside then
			if recordedMode then
				recordDelayEnd = nil
				isReplaying    = false
				jumpTriggered  = false
				lastMoveTarget = nil
				resetFallbackState()
			end

			if not wasInRadius then
				wasInRadius        = true
				sideReached        = false
				currentSide        = (math.random(1, 2) == 1) and "left" or "right"
				local sidePos      = getSidePosition(targetRoot, currentSide).Position
				-- Only move to side position if it's safe
				if isSafePosition(sidePos) then
					sideTargetPosition = sidePos
					smoothMove(humanoid, sideTargetPosition)
				else
					-- Try opposite side
					local otherSide = (currentSide == "left") and "right" or "left"
					local altPos    = getSidePosition(targetRoot, otherSide).Position
					sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
					smoothMove(humanoid, sideTargetPosition)
				end
			elseif not sideReached then
				if sideTargetPosition then
					local distToSide = (rootPart.Position - sideTargetPosition).Magnitude
					if distToSide <= 2 then
						sideReached = true
					else
						smoothMove(humanoid, sideTargetPosition)
					end
				end
			end

			lastWasInside = isInside
			lastTargetPos = targetRoot.Position
			return
		else
			if wasInRadius then
				wasInRadius        = false
				currentSide        = nil
				sideTargetPosition = nil
				sideReached        = false
			end
		end

		-- ── Recorded‑mode replay ─────────────────────────────────────
		if recordedMode then
			local targetMoved = lastTargetPos and (targetRoot.Position - lastTargetPos).Magnitude < 20
			if not fallbackActive and lastWasInside and not isInside and targetMoved then
				recordedPositions   = {}
				recordedJumpIndices = {}
				replayIndex         = 1
				recordDelayEnd      = tick() + RECORD_DELAY
				isReplaying         = false
				jumpTriggered       = false
				lastMoveTarget      = nil
				resetFallbackState()
			end

			if recordDelayEnd then
				if tick() >= recordDelayEnd then
					recordDelayEnd = nil
					isReplaying    = true
					replayIndex    = 1
					jumpTriggered  = false
				else
					smoothMove(humanoid, rootPart.Position)
					lastWasInside = isInside
					lastTargetPos = targetRoot.Position
					return
				end
			end

			if isReplaying and not fallbackActive then
				if #recordedPositions > 0 and replayIndex <= #recordedPositions then
					local targetPos = recordedPositions[replayIndex]

					-- ── ANTI‑VOID: skip unsafe replay waypoints ──────────────
					if not isSafePosition(targetPos) then
						-- Skip this waypoint and try the next one
						replayIndex   = replayIndex + 1
						jumpTriggered = false
						lastMoveTarget = nil
						lastWasInside = isInside
						lastTargetPos = targetRoot.Position
						return
					end
					-- ─────────────────────────────────────────────────────────

					smoothMove(humanoid, targetPos)

					local justJumped = false
					if recordedJumpIndices[replayIndex] and not jumpTriggered then
						humanoid.Jump = true
						jumpTriggered = true
						justJumped    = true
						stuckTimer    = -1.0
					elseif jumpTriggered then
						if humanoid.FloorMaterial ~= Enum.Material.Air then
							-- landed
						else
							humanoid.Jump = false
							jumpTriggered = false
							stuckTimer    = 0
						end
					elseif not recordedJumpIndices[replayIndex] then
						jumpTriggered = false
					end

					local advance      = false
					local distToTarget = (rootPart.Position - targetPos).Magnitude

					if recordedJumpIndices[replayIndex] then
						local horizontalDist = (
							Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) -
							Vector3.new(targetPos.X, 0, targetPos.Z)
						).Magnitude
						if horizontalDist < REPLAY_ADVANCE_RADIUS + 3 then
							advance = true
						elseif not jumpTriggered and not justJumped then
							advance = true
						end
					else
						if distToTarget < REPLAY_ADVANCE_RADIUS then
							advance = true
						end
					end

					if advance then
						replayIndex   = replayIndex + 1
						jumpTriggered = false
						stuckTimer    = 0
						lastMoveTarget = nil
					end

					if autoSwitchEnabled then
						if lastPosition then
							local moved = (rootPart.Position - lastPosition).Magnitude
							if moved < 0.5 then
								if stuckTimer >= 0 and not jumpTriggered then
									stuckTimer = stuckTimer + deltaTime
									if stuckTimer >= STUCK_TIMEOUT then
										fallbackActive         = true
										fallbackPath           = nil
										fallbackLastPathUpdate = 0
										fallbackLastPathTarget = nil
										fallbackLastMoveTarget = nil
										fallbackWaypointIndex  = 1
										stuckTimer             = 0
										lastMoveTarget         = nil
										Status.Text            = "Stuck – using pathfinding"
									end
								elseif stuckTimer < 0 then
									stuckTimer = math.min(stuckTimer + deltaTime, 0)
								end
							else
								stuckTimer = 0
								if fallbackActive then
									lastMoveTarget = nil
									resetFallbackState()
								end
							end
						end
						lastPosition = rootPart.Position
					end
				else
					smoothMove(humanoid, rootPart.Position)
				end

				lastWasInside = isInside
				lastTargetPos = targetRoot.Position
				return
			end
		end

		-- ── Fallback pathfinding (anti‑void wired in) ─────────────────
		if recordedMode and fallbackActive then
			if distance <= STOP_DISTANCE then
				local nearestIdx = findNearestWaypointIndex(rootPart.Position)
				replayIndex  = nearestIdx
				isReplaying  = true
				resetFallbackState()
				Status.Text  = "Resuming replay"
				lastWasInside = isInside
				lastTargetPos = targetRoot.Position
				return
			end

			-- Check target reachability: if target itself is over a void, hold position
			if not isSafePosition(targetRoot.Position) then
				fallbackSmoothMove(humanoid, rootPart.Position)
				lastWasInside = isInside
				lastTargetPos = targetRoot.Position
				return
			end

			local needRecompute = false
			if not fallbackPath then
				needRecompute = true
			elseif fallbackWaypointIndex > #fallbackPath:GetWaypoints() then
				needRecompute = true
			elseif fallbackLastPathTarget then
				local targetDrift = (targetRoot.Position - fallbackLastPathTarget).Magnitude
				if targetDrift > FALLBACK_TARGET_MOVED_THRESHOLD
					and (now - fallbackLastPathUpdate) >= PATH_UPDATE_INTERVAL then
					needRecompute = true
				end
			end

			if needRecompute then
				fallbackLastPathUpdate = now
				local path = PathfindingService:CreatePath({
					AgentRadius     = 2,
					AgentHeight     = 5,
					AgentCanJump    = true,
					AgentJumpHeight = 7.5,
					AgentMaxSlope   = 45,
					WaypointSpacing = 4,
				})
				local success = pcall(function()
					path:ComputeAsync(rootPart.Position, targetRoot.Position)
				end)
				if success and path.Status == Enum.PathStatus.Success then
					local wps      = path:GetWaypoints()
					local startIdx = 1
					if #wps > 1 and (rootPart.Position - wps[1].Position).Magnitude < WAYPOINT_RADIUS then
						startIdx = 2
					end
					fallbackPath           = path
					fallbackWaypointIndex  = startIdx
					fallbackLastPathTarget = targetRoot.Position
					fallbackLastMoveTarget = nil
				else
					fallbackPath = nil
				end
			end

			if fallbackPath then
				local waypoints = fallbackPath:GetWaypoints()

				-- Advance past already‑reached waypoints
				while fallbackWaypointIndex <= #waypoints do
					local wp = waypoints[fallbackWaypointIndex]
					if (rootPart.Position - wp.Position).Magnitude < WAYPOINT_RADIUS then
						fallbackWaypointIndex  = fallbackWaypointIndex + 1
						fallbackLastMoveTarget = nil
					else
						break
					end
				end

				if fallbackWaypointIndex <= #waypoints then
					local wp = waypoints[fallbackWaypointIndex]

					-- ── ANTI‑VOID: skip unsafe fallback waypoints ────────────
					if not isSafePosition(wp.Position) then
						-- Skip this waypoint; force a path recompute next frame
						fallbackWaypointIndex  = fallbackWaypointIndex + 1
						fallbackLastMoveTarget = nil
						-- If we just exhausted all waypoints, clear path so we recompute
						if fallbackWaypointIndex > #waypoints then
							fallbackPath = nil
						end
						lastWasInside = isInside
						lastTargetPos = targetRoot.Position
						return
					end
					-- ─────────────────────────────────────────────────────────

					fallbackSmoothMove(humanoid, wp.Position)
					if wp.Action == Enum.PathWaypointAction.Jump then
						humanoid.Jump = true
					end
				else
					fallbackPath = nil
				end
			else
				-- Last resort: direct move only if destination is safe
				fallbackLastMoveTarget = nil
				local dest = isSafePosition(targetRoot.Position)
					and targetRoot.Position
					or  rootPart.Position
				fallbackSmoothMove(humanoid, dest)
			end

			lastWasInside = isInside
			lastTargetPos = targetRoot.Position
			return
		end

		-- ── Normal following (pathfinding) ───────────────────────────
		local recompute = false
		if not currentPath then
			recompute = true
		elseif not lastPathTarget or (targetRoot.Position - lastPathTarget).Magnitude > 5 then
			recompute = true
		elseif now - lastPathUpdate >= PATH_UPDATE_INTERVAL then
			recompute = true
		end

		if recompute then
			lastPathUpdate = now
			if isSafePosition(targetRoot.Position) then
				local path = PathfindingService:CreatePath({
					AgentRadius    = 2,
					AgentHeight    = 5,
					AgentCanJump   = true,
					AgentJumpHeight = 7.5,
					AgentMaxSlope  = 45,
					WaypointSpacing = 4,
				})
				local success = pcall(function()
					path:ComputeAsync(rootPart.Position, targetRoot.Position)
				end)
				if success and path.Status == Enum.PathStatus.Success then
					currentPath          = path
					currentWaypointIndex = 1
					lastPathTarget       = targetRoot.Position
				else
					currentPath = nil
				end
			else
				currentPath = nil
			end
		end

		if distance < directMoveThreshold then
			currentPath = nil
			if isSafePosition(targetRoot.Position) then
				smoothMove(humanoid, targetRoot.Position)
			else
				smoothMove(humanoid, rootPart.Position)
			end
		elseif currentPath then
			local waypoints = currentPath:GetWaypoints()
			if currentWaypointIndex <= #waypoints then
				local waypoint = waypoints[currentWaypointIndex]
				if isSafePosition(waypoint.Position) then
					smoothMove(humanoid, waypoint.Position)
				else
					-- Unsafe normal waypoint: invalidate path, recompute next frame
					currentPath = nil
				end
				if waypoint.Action == Enum.PathWaypointAction.Jump then
					humanoid.Jump = true
				else
					humanoid.Jump = false
				end
				if (rootPart.Position - waypoint.Position).Magnitude < WAYPOINT_RADIUS then
					currentWaypointIndex = currentWaypointIndex + 1
				end
			else
				currentPath = nil
			end
		else
			if isSafePosition(targetRoot.Position) then
				smoothMove(humanoid, targetRoot.Position)
			else
				smoothMove(humanoid, rootPart.Position)
			end
		end

		lastWasInside = isInside
		lastTargetPos = targetRoot.Position
	end)
end

