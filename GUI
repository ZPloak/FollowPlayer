local recordedJumpIndices = {}
local recordConnection  = nil
local replayIndex       = 1
local recordDelayEnd    = nil
local isReplaying       = false
local jumpTriggered     = false

local autoSwitchEnabled = true
local fallbackActive    = false
local lastPosition      = nil
local stuckTimer        = 0
local fallbackPath      = nil
local fallbackWaypointIndex = 1
local fallbackTarget    = nil
local fallbackLastPathUpdate = 0
local fallbackLastPathTarget = nil

local lastSeatExitTime  = 0
local lastMoveTarget    = nil
local lastStatusUpdate  = 0

-- Simplified safe position check (disabled by default)
local function isSafePosition(pos)
    if not USE_SAFETY_RAYCAST then return true end
    -- Raycast code (optional) – omitted for brevity
    return true
end

local function smoothMove(humanoid, targetPos)
    if not targetPos or not humanoid then return end
    if lastMoveTarget and (targetPos - lastMoveTarget).Magnitude < MOVE_TOLERANCE then return end
    lastMoveTarget = targetPos
    pcall(function()
        humanoid:MoveTo(targetPos)
    end)
end

local function findPlayer(searchText)
    if searchText == "" then return nil end
    local searchLower = searchText:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Name:lower():find(searchLower, 1, true)
                or p.DisplayName:lower():find(searchLower, 1, true) then
                return p
            end
        end
    end
    return nil
end

local function getSidePosition(targetRoot, side)
    if side == "left" then
        return targetRoot.CFrame * CFrame.new(-SIDE_DISTANCE, 0, 0)
    elseif side == "right" then
        return targetRoot.CFrame * CFrame.new(SIDE_DISTANCE, 0, 0)
    end
    return targetRoot.Position
end

local function isSeated(humanoid)
    return humanoid and humanoid.SeatPart ~= nil
end

local function stopFollowing()
    isFollowing = false
    targetPlayer = nil
    wasInRadius = false
    currentSide = nil
    sideTargetPosition = nil
    recordDelayEnd = nil
    isReplaying = false
    jumpTriggered = false
    fallbackActive = false
    stuckTimer = 0
    lastPosition = nil
    lastMoveTarget = nil
    fallbackPath = nil
    fallbackTarget = nil
    fallbackLastPathUpdate = 0
    fallbackLastPathTarget = nil

    if recordedMode then
        recordedMode = false
        if recordConnection then recordConnection:Disconnect() end
        recordedPositions = {}
        recordedJumpIndices = {}
        replayIndex = 1
        RecordButton.Text = "Enable Recorded Mode"
        Status.Text = "Recorded mode disabled"
    end

    if followConnection then
        followConnection:Disconnect()
        followConnection = nil
    end

    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum and hum.Parent and hum.Parent:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                hum:MoveTo(hum.Parent.HumanoidRootPart.Position)
            end)
        end
    end

    Status.Text = "Stopped"
    Status.TextColor3 = Color3.fromRGB(200, 200, 200)
end

local function startRecording()
    if recordConnection then recordConnection:Disconnect() end
    recordedPositions = {}
    recordedJumpIndices = {}
    replayIndex = 1
    recordDelayEnd = nil
    isReplaying = false
    jumpTriggered = false

    local lastJumpState = false
    local lastRecordTime = tick()

    recordConnection = RunService.RenderStepped:Connect(function()
        if not isFollowing or not targetPlayer or not targetPlayer.Character then return end
        local targetChar = targetPlayer.Character
        local localChar = player.Character
        if not targetChar or not localChar then return end
        local targetRoot     = targetChar:FindFirstChild("HumanoidRootPart")
        local targetHumanoid = targetChar:FindFirstChild("Humanoid")
        local localRoot      = localChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot or not targetHumanoid then return end

        local distance = (targetRoot.Position - localRoot.Position).Magnitude
        if distance > STOP_DISTANCE then
            local now = tick()
            if now - lastRecordTime >= RECORD_INTERVAL then
                table.insert(recordedPositions, targetRoot.Position)
                local idx = #recordedPositions
                local isJumping = targetHumanoid.Jump or (targetRoot.AssemblyLinearVelocity.Y > 5)
                if isJumping and not lastJumpState then
                    recordedJumpIndices[idx] = true
                end
                lastJumpState = isJumping
                lastRecordTime = now
            end
        end
    end)
end

local function toggleRecordedMode()
    if not isFollowing then
        Status.Text = "Start following first"
        return
    end
    recordedMode = not recordedMode
    if recordedMode then
        startRecording()
        RecordButton.Text = "Disable Recorded Mode"
        Status.Text = "Recording path"
        Status.TextColor3 = Color3.fromRGB(255, 200, 100)
    else
        if recordConnection then recordConnection:Disconnect() end
        recordedPositions = {}
        recordedJumpIndices = {}
        replayIndex = 1
        recordDelayEnd = nil
        isReplaying = false
        fallbackActive = false
        stuckTimer = 0
        lastMoveTarget = nil
        fallbackPath = nil
        fallbackTarget = nil
        fallbackLastPathUpdate = 0
        fallbackLastPathTarget = nil
        RecordButton.Text = "Enable Recorded Mode"
        Status.Text = "Recorded mode off"
        Status.TextColor3 = Color3.fromRGB(100, 200, 255)
    end
end

local function toggleAutoSwitch()
    autoSwitchEnabled = not autoSwitchEnabled
    AutoSwitchButton.Text = autoSwitchEnabled and "Auto‑Switcher: ON" or "Auto‑Switcher: OFF"
    if not autoSwitchEnabled then
        fallbackActive = false
        stuckTimer = 0
    end
end

local function findNearestWaypointIndex(pos)
    if #recordedPositions == 0 then return 1 end
    local bestIdx = 1
    local bestDist = (pos - recordedPositions[1]).Magnitude
    for i = 2, #recordedPositions do
        local d = (pos - recordedPositions[i]).Magnitude
        if d < bestDist then
            bestDist = d
            bestIdx = i
        end
    end
    return bestIdx
end

local function startFollowing()
    if followConnection then followConnection:Disconnect() end

    local lastPathUpdate       = 0
    local currentPath          = nil
    local currentWaypointIndex = 0
    local lastWasInside        = false
    local lastSideUpdateTime   = 0
    local lastPathTarget       = nil
    local directMoveThreshold  = STOP_DISTANCE + 3
    local lastTargetPos        = nil

    followConnection = RunService.RenderStepped:Connect(function(deltaTime)
        if not isFollowing or not targetPlayer or not targetPlayer.Parent then
            if targetPlayer and not targetPlayer.Parent then
                stopFollowing()
                Status.Text = "Target left"
            end
            return
        end

        local character      = player.Character
        local targetChar     = targetPlayer.Character
        if not character or not targetChar then return end

        local humanoid       = character:FindFirstChild("Humanoid")
        local rootPart       = character:FindFirstChild("HumanoidRootPart")
        local targetHumanoid = targetChar:FindFirstChild("Humanoid")
        local targetRoot     = targetChar:FindFirstChild("HumanoidRootPart")
        if not humanoid or not rootPart or not targetRoot then return end

        -- Anti‑seat
        local followerSeated = isSeated(humanoid)
        local targetSeated   = targetHumanoid and isSeated(targetHumanoid)
        if followerSeated and not targetSeated then
            humanoid.Sit = false
            local now = tick()
            if now - lastSeatExitTime > 1.0 then
                humanoid.Jump = true
                lastSeatExitTime = now
                Status.Text = "Jumping off seat"
            end
            smoothMove(humanoid, rootPart.Position)
        end

        local distance = (targetRoot.Position - rootPart.Position).Magnitude
        local isInside = distance <= STOP_DISTANCE
        local now = tick()

        -- Status label
        if now - lastStatusUpdate > 0.2 then
            lastStatusUpdate = now
            local mode = ""
            if recordedMode then
                if fallbackActive then
                    mode = " [FALLBACK]"
                elseif isReplaying then
                    mode = " [REPLAY]"
                else
                    mode = " [REC]"
                end
            end
            Status.Text = string.format("%s%s (%.0f)", targetPlayer.DisplayName, mode, distance)
            Status.TextColor3 = recordedMode
                and Color3.fromRGB(255, 200, 100)
                or  Color3.fromRGB(100, 200, 255)
        end

        -- Side‑stand behaviour when close
        if isInside then
            if recordedMode then
                recordDelayEnd = nil
                isReplaying    = false
                jumpTriggered  = false
                fallbackActive = false
                stuckTimer     = 0
                lastMoveTarget = nil
                fallbackPath   = nil
                fallbackTarget = nil
                fallbackLastPathUpdate = 0
                fallbackLastPathTarget = nil
            end

            if not wasInRadius then
                wasInRadius          = true
                currentSide          = (math.random(1, 2) == 1) and "left" or "right"
                sideTargetPosition   = getSidePosition(targetRoot, currentSide).Position
                lastSideUpdateTime   = now
                if isSafePosition(sideTargetPosition) then
                    smoothMove(humanoid, sideTargetPosition)
                end
            else
                if now - lastSideUpdateTime >= SIDE_UPDATE_INTERVAL then
                    sideTargetPosition = getSidePosition(targetRoot, currentSide).Position
                    lastSideUpdateTime = now
                end
                if sideTargetPosition then
                    if (rootPart.Position - sideTargetPosition).Magnitude < 2 then
                        smoothMove(humanoid, rootPart.Position)
                    elseif isSafePosition(sideTargetPosition) then
                        smoothMove(humanoid, sideTargetPosition)
                    end
                end
            end

            lastWasInside = isInside
            lastTargetPos = targetRoot.Position
            return
        else
            if wasInRadius then
                wasInRadius        = false
                currentSide        = nil
                sideTargetPosition = nil
            end
        end

        -- Recorded mode replay
        if recordedMode then
            local targetMoved = lastTargetPos and (targetRoot.Position - lastTargetPos).Magnitude < 20
            if not fallbackActive and lastWasInside and not isInside and targetMoved then
                recordedPositions = {}
                recordedJumpIndices = {}
                replayIndex    = 1
                recordDelayEnd = tick() + RECORD_DELAY
                isReplaying    = false
                jumpTriggered  = false
                fallbackActive = false
                stuckTimer     = 0
                lastMoveTarget = nil
                fallbackPath   = nil
                fallbackTarget = nil
                fallbackLastPathUpdate = 0
                fallbackLastPathTarget = nil
            end

            if recordDelayEnd then
                if tick() >= recordDelayEnd then
                    recordDelayEnd = nil
                    isReplaying    = true
                    replayIndex    = 1
                    jumpTriggered  = false
                    fallbackActive = false
                else
                    smoothMove(humanoid, rootPart.Position)
                    lastWasInside = isInside
                    lastTargetPos = targetRoot.Position
                    return
                end
            end

            if isReplaying and not fallbackActive then
                if #recordedPositions > 0 and replayIndex <= #recordedPositions then
                    local targetPos = recordedPositions[replayIndex]

                    if isSafePosition(targetPos) then
                        smoothMove(humanoid, targetPos)
                    else
                        smoothMove(humanoid, rootPart.Position)
                    end

                    if recordedJumpIndices[replayIndex] and not jumpTriggered then
                        humanoid.Jump = true
                        jumpTriggered = true
                    elseif jumpTriggered then
                        if humanoid.FloorMaterial ~= Enum.Material.Air then
                            humanoid.Jump = false
                            jumpTriggered = false
                        end
                    elseif not recordedJumpIndices[replayIndex] then
                        jumpTriggered = false
                    end

                    local advance = false
                    local distToTarget = (rootPart.Position - targetPos).Magnitude
                    if recordedJumpIndices[replayIndex] then
                        local horizontalDist = (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) -
                                                Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude
                        if horizontalDist < REPLAY_ADVANCE_RADIUS then
                            advance = true
                        end
                    else
                        if distToTarget < REPLAY_ADVANCE_RADIUS then
                            advance = true
                        end
                    end

                    if advance then
                        replayIndex    = replayIndex + 1
                        jumpTriggered  = false
                        stuckTimer     = 0
                        lastMoveTarget = nil
                    end

                    if autoSwitchEnabled then
                        if lastPosition then
                            local moved = (rootPart.Position - lastPosition).Magnitude
                            if moved < 0.5 then
                                stuckTimer = stuckTimer + deltaTime
                                if stuckTimer >= STUCK_TIMEOUT then
                                    fallbackActive         = true
                                    stuckTimer             = 0
                                    fallbackPath           = nil
                                    fallbackTarget         = nil
                                    fallbackLastPathUpdate = 0
                                    fallbackLastPathTarget = nil
                                    lastMoveTarget         = nil
                                    Status.Text            = "Stuck – using pathfinding"
                                end
                            else
                                stuckTimer     = 0
                                if fallbackActive then
                                    fallbackActive         = false
                                    lastMoveTarget         = nil
                                    fallbackPath           = nil
                                    fallbackTarget         = nil
                                    fallbackLastPathUpdate = 0
                                    fallbackLastPathTarget = nil
                                end
                            end
                        end
                        lastPosition = rootPart.Position
                    end
                else
                    smoothMove(humanoid, rootPart.Position)
                end

                lastWasInside = isInside
                lastTargetPos = targetRoot.Position
                return
            end
        end

        -- FALLBACK MODE
        if recordedMode and fallbackActive then
            if distance <= STOP_DISTANCE then
                fallbackActive         = false
                fallbackPath           = nil
                fallbackTarget         = nil
                fallbackLastPathUpdate = 0
                fallbackLastPathTarget = nil
                lastMoveTarget         = nil
                stuckTimer             = 0
                lastPosition           = nil
                local nearestIdx = findNearestWaypointIndex(rootPart.Position)
                replayIndex  = nearestIdx
                isReplaying  = true
                Status.Text  = "Resuming replay"
                lastWasInside = isInside
                lastTargetPos = targetRoot.Position
                return
            end

            if not isSafePosition(targetRoot.Position) then
                smoothMove(humanoid, rootPart.Position)
                lastWasInside = isInside
                lastTargetPos = targetRoot.Position
                return
            end

            local fbRecompute = false
            if not fallbackPath then
                fbRecompute = true
            elseif not fallbackLastPathTarget
                or (targetRoot.Position - fallbackLastPathTarget).Magnitude > FALLBACK_RECOMPUTE_DIST then
                fbRecompute = true
            elseif now - fallbackLastPathUpdate >= PATH_UPDATE_INTERVAL then
                fbRecompute = true
            end

            if fbRecompute then
                fallbackLastPathUpdate = now
                local path = PathfindingService:CreatePath({
                    AgentRadius    = 2,
                    AgentHeight    = 5,
                    AgentCanJump   = true,
                    AgentJumpHeight = 7.5,
                    AgentMaxSlope  = 45,
                    WaypointSpacing = 4,
                })
                local success = pcall(function()
                    path:ComputeAsync(rootPart.Position, targetRoot.Position)
                end)
                if success and path.Status == Enum.PathStatus.Success then
                    fallbackPath           = path
                    fallbackWaypointIndex  = 1
                    fallbackLastPathTarget = targetRoot.Position
                else
                    fallbackPath = nil
                end
            end

            if fallbackPath then
                local waypoints = fallbackPath:GetWaypoints()
                if fallbackWaypointIndex <= #waypoints then
                    local wp = waypoints[fallbackWaypointIndex]
                    if isSafePosition(wp.Position) then
                        smoothMove(humanoid, wp.Position)
                    else
                        smoothMove(humanoid, rootPart.Position)
                    end
                    if wp.Action == Enum.PathWaypointAction.Jump then
                        humanoid.Jump = true
                    else
                        humanoid.Jump = false
                    end
                    if (rootPart.Position - wp.Position).Magnitude < WAYPOINT_RADIUS then
                        fallbackWaypointIndex = fallbackWaypointIndex + 1
                    end
                else
                    fallbackPath           = nil
                    fallbackLastPathTarget = nil
                end
            else
                lastMoveTarget = nil
                smoothMove(humanoid, targetRoot.Position)
            end

            lastWasInside = isInside
            lastTargetPos = targetRoot.Position
            return
        end

        -- NORMAL FOLLOWING
        local recompute = false
        if not currentPath then
            recompute = true
        elseif not lastPathTarget or (targetRoot.Position - lastPathTarget).Magnitude > 5 then
            recompute = true
        elseif now - lastPathUpdate >= PATH_UPDATE_INTERVAL then
            recompute = true
        end

        if recompute then
            lastPathUpdate = now
            if isSafePosition(targetRoot.Position) then
                local path = PathfindingService:CreatePath({
                    AgentRadius    = 2,
                    AgentHeight    = 5,
                    AgentCanJump   = true,
                    AgentJumpHeight = 7.5,
                    AgentMaxSlope  = 45,
                    WaypointSpacing = 4,
                })
                local success = pcall(function()
                    path:ComputeAsync(rootPart.Position, targetRoot.Position)
                end)
                if success and path.Status == Enum.PathStatus.Success then
                    currentPath = path
                    currentWaypointIndex = 1
                    lastPathTarget = targetRoot.Position
                else
                    currentPath = nil
                end
            else
                currentPath = nil
            end
        end

        if distance < directMoveThreshold then
            currentPath = nil
            if isSafePosition(targetRoot.Position) then
                smoothMove(humanoid, targetRoot.Position)
            else
                smoothMove(humanoid, rootPart.Position)
            end
        elseif currentPath then
            local waypoints = currentPath:GetWaypoints()
            if currentWaypointIndex <= #waypoints then
                local waypoint = waypoints[currentWaypointIndex]
                if isSafePosition(waypoint.Position) then
                    smoothMove(humanoid, waypoint.Position)
                else
                    smoothMove(humanoid, rootPart.Position)
                end
                if waypoint.Action == Enum.PathWaypointAction.Jump then
                    humanoid.Jump = true
                else
                    humanoid.Jump = false
                end
                if (rootPart.Position - waypoint.Position).Magnitude < WAYPOINT_RADIUS then
                    currentWaypointIndex = currentWaypointIndex + 1
                end
            else
                currentPath = nil
            end
        else
            if isSafePosition(targetRoot.Position) then
                smoothMove(humanoid, targetRoot.Position)
            else
                smoothMove(humanoid, rootPart.Position)
            end
        end

        lastWasInside = isInside
        lastTargetPos = targetRoot.Position
    end)
end

-- Button actions
FollowButton.MouseButton1Click:Connect(function()
    local searchText = SearchBar.Text
    if searchText == "" then
        Status.Text = "Enter a name"
        Status.TextColor3 = Color3.fromRGB(255, 200, 100)
        return
    end
    local found = findPlayer(searchText)
    if found then
        stopFollowing()
        targetPlayer = found
        isFollowing  = true
        startFollowing()
        Status.Text = "Following " .. found.DisplayName
        Status.TextColor3 = Color3.fromRGB(100, 200, 255)
        SearchBar.Text = found.Name
    else
        Status.Text = "Not found"
        Status.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

CancelButton.MouseButton1Click:Connect(function()
    stopFollowing()
    SearchBar.Text = ""
    Status.Text = "Ready"
    Status.TextColor3 = Color3.fromRGB(200, 200, 200)
end)

RecordButton.MouseButton1Click:Connect(toggleRecordedMode)
AutoSwitchButton.MouseButton1Click:Connect(toggleAutoSwitch)
