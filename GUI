local function findPlayer(searchText)
	if searchText == "" then return nil end
	local searchLower = searchText:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			if p.Name:lower():find(searchLower, 1, true) or p.DisplayName:lower():find(searchLower, 1, true) then
				return p
			end
		end
	end
	return nil
end

local function getSidePosition(targetRoot, side)
	if side == "left" then
