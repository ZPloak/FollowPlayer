	fallbackActive = false
	fallbackPath = nil
	fallbackLastPathUpdate = 0
	fallbackLastPathTarget = nil
	fallbackLastMoveTarget = nil
	fallbackWaypointIndex = 1
	stuckTimer = 0
	lastPosition = nil
end

local function stopFollowing()
	print("============================================")
	print("[STOP] Stopping follow")
	print("============================================")
	isFollowing = false
	targetPlayer = nil
	inSideStand = false
	currentSide = nil
	sideTargetPosition = nil
	sideReached = false
	recordDelayEnd = nil
	isReplaying = false
	jumpTriggered = false
	resetFallbackState()
	lastMoveTargetPos = nil
	manualControlActive = false

	sillyActive = false
	victimIsMoving = false
	victimStillTimer = 0
	victimHasMovedSinceStart = false
	sillyJustCompleted = false
	currentSillySequence = nil

	if recordedMode then
		recordedMode = false
		if recordConnection then recordConnection:Disconnect() end
		recordedPositions = {}
		recordedJumpIndices = {}
		replayIndex = 1
		RecordButton.Text = "Enable Recorded Mode"
		Status.Text = "Recorded mode disabled"
	end

	if followConnection then
		followConnection:Disconnect()
		followConnection = nil
	end

	local char = player.Character
	if char then
		local hum = char:FindFirstChild("Humanoid")
		if hum and hum.Parent and hum.Parent:FindFirstChild("HumanoidRootPart") then
			pcall(function() hum:MoveTo(hum.Parent.HumanoidRootPart.Position) end)
		end
	end
	Status.Text = "Stopped"
	Status.TextColor3 = Color3.fromRGB(200, 200, 200)
end

local function startRecording()
	if recordConnection then recordConnection:Disconnect() end
	recordedPositions = {}
	recordedJumpIndices = {}
	replayIndex = 1
	recordDelayEnd = nil
	isReplaying = false
	jumpTriggered = false
	local lastJumpState = false
	local lastRecordTime = tick()
	recordConnection = RunService.RenderStepped:Connect(function()
		if not isFollowing or not targetPlayer or not targetPlayer.Character then return end
		local targetChar = targetPlayer.Character
		local localChar = player.Character
		if not targetChar or not localChar then return end
		local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local localRoot = localChar:FindFirstChild("HumanoidRootPart")
		if not targetRoot or not localRoot or not targetHumanoid then return end
		local distance = (targetRoot.Position - localRoot.Position).Magnitude
		if distance > EXIT_DISTANCE then
			local now = tick()
			if now - lastRecordTime >= RECORD_INTERVAL then
				local recPos = targetRoot.Position
				if isSafePosition(recPos) then
					table.insert(recordedPositions, recPos)
					local idx = #recordedPositions
					local isJumping = targetHumanoid.Jump or (targetRoot.AssemblyLinearVelocity.Y > 5)
					if isJumping and not lastJumpState then
						recordedJumpIndices[idx] = true
					end
					lastJumpState = isJumping
				end
				lastRecordTime = now
			end
		end
	end)
end

local function toggleRecordedMode()
	if not isFollowing then
		Status.Text = "Start following first"
		return
	end
	recordedMode = not recordedMode
	print("[RECORD] Mode:", recordedMode and "ON" or "OFF")
