						staringActive = false
						
						inSideStand = true
						sideReached = false
						currentSide = (blockCount % 2 == 1) and "left" or "right"
						local sidePos = getSidePosition(targetRoot, currentSide).Position
						if isSafePosition(sidePos) then
							sideTargetPosition = sidePos
						else
							local otherSide = (currentSide == "left") and "right" or "left"
							local altPos = getSidePosition(targetRoot, otherSide).Position
							sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
						end
						
						local waitTime = 0
						while waitTime < 2.0 do
							if sideReached then break end
							task.wait(0.1)
							waitTime = waitTime + 0.1
						end
						
						blockCount = 0
						lastBlockerName = nil
						
					else
						local direction = (targetRoot.Position - rootPart.Position).Unit
						local perpendicular = Vector3.new(-direction.Z, 0, direction.X)
						local moveDirection = (blockCount % 2 == 1) and perpendicular or -perpendicular
						debugPrint("[SOCIAL] Stepping aside")
						
						local finalTarget = rootPart.Position + moveDirection * STEP_DISTANCE
						local moveTime = 0
						while moveTime < 1.5 do
							if not targetRoot or not rootPart then break end
							smoothMove(humanoid, finalTarget)
							if (rootPart.Position - finalTarget).Magnitude < 1.5 then break end
							task.wait(0.1)
							moveTime = moveTime + 0.1
						end
					end
					
					debugPrint("[SOCIAL] Finished moving")
					
					task.wait(1.0)
					
					isMovingAside = false
					
				else
					lastBlockerName = nil
					blockCount = 0
				end
			end
		else
			lastBlockerName = nil
			blockCount = 0
		end

		local wasMoving = victimIsMoving
		if targetHumanoid then
			if isVictimSeated(targetHumanoid) then
				victimIsMoving = false
			else
				local moveDir = targetHumanoid.MoveDirection.Magnitude
				local vel = targetRoot.AssemblyLinearVelocity.Magnitude
				victimIsMoving = (moveDir > 0.5) or (vel > 2)
				if wasMoving ~= victimIsMoving then
					debugPrint("[VICTIM]", victimIsMoving and "Started moving" or "Stopped moving")
				end
			end
			if victimIsMoving then
				victimHasMovedSinceStart = true
				sillyJustCompleted = false
			end
			
			if not victimHasMovedSinceStart and distance <= ENTER_DISTANCE then
				victimHasMovedSinceStart = true
			end
		else
			victimIsMoving = false
		end

		if now - lastStatusUpdate > 0.2 then
			lastStatusUpdate = now
			local silly = (sillyActive or actionActive) and " [SILLY]" or ""
			local cam = (CAMERA_ENABLED and distance > CAMERA_TRACK_MIN and distance <= CAMERA_TRACK_MAX) and " [CAM]" or ""
			Status.Text = string.format("%s%s%s (%.0f)", targetPlayer.DisplayName, silly, cam, distance)
			Status.TextColor3 = Color3.fromRGB(100, 200, 255)
		end

		-- ===== TRIGGER SILLY SEQUENCES (MVs) WHEN VICTIM STILL =====
		if not sillyActive and not actionActive and not isFollowerSeated() and SILLY_ENABLED and now >= sillyCooldownEnd then
			if not victimIsMoving and distance <= EXIT_DISTANCE and distance < MAX_SILLY_DISTANCE then
				victimStillTimer = victimStillTimer + deltaTime
				if math.floor(victimStillTimer) > math.floor(victimStillTimer - deltaTime) then
					debugPrint("[TIMER] Still:", math.floor(victimStillTimer), "/", VICTIM_STILL_TIME)
				end
				if victimStillTimer >= VICTIM_STILL_TIME then
					currentSillySequence, seqIndex = pickRandomSillySequence()
					if currentSillySequence then
						local seqName = SILLY_SEQUENCE_NAMES[seqIndex] or ("Movement #" .. seqIndex)
						debugPrint("[SILLY] TRIGGERED! Playing " .. seqName)
						sillyActive = true
						sillyIndex = 1
						sillyJumped = false
						sillyLastPosition = nil
						sillyStuckTimer = 0
						victimStillTimer = 0
						sillyCooldownEnd = now + SILLY_COOLDOWN_TIME
						inSideStand = false
						staringActive = false
						mimicActive = false
					else
						debugPrint("[SILLY] No movements available!")
						victimStillTimer = 0
					end
				end
			else
				if victimStillTimer > 0.5 then
					debugPrint("[TIMER] Reset - " .. (victimIsMoving and "moved" or "outside 8 studs"))
				end
				victimStillTimer = 0
			end
		else
			if victimStillTimer > 0.5 and victimIsMoving then
				debugPrint("[TIMER] Reset - moved")
			end
			victimStillTimer = 0
		end

		-- ===== VICTIM PROMPT CLICK =====
		if RANDOM_CLICK_ENABLED and targetRoot and not sillyActive and not actionActive then
			local now = tick()
			if now - lastVictimPromptScan > 2 then
				lastVictimPromptScan = now
				
				local victimPrompts = {}
				for _, obj in ipairs(targetChar:GetDescendants()) do
					if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
						local parent = obj.Parent
						if parent and parent:IsA("BasePart") then
							local dist = (parent.Position - rootPart.Position).Magnitude
							if dist <= 8 then
								table.insert(victimPrompts, obj)
							end
						end
					end
				end
				
				if #victimPrompts > 0 then
					debugPrint("Found " .. #victimPrompts .. " prompt(s) on victim - clicking now")
					
					victimStillTimer = 0
					
					if not targetChar or not targetChar.Parent then return end
					
					local anySuccess = false
					for _, obj in ipairs(victimPrompts) do
						local parent = obj.Parent
						local newDist = (parent.Position - rootPart.Position).Magnitude
						if newDist <= 8 then
							pcall(function()
								if obj:IsA("ClickDetector") then
									obj:Fire()
								elseif obj:IsA("ProximityPrompt") then
									local holdTime = obj.HoldDuration or 0
									if holdTime > 0 then
										obj:InputHoldBegin()
										task.wait(holdTime + 0.05)
										obj:InputHoldEnd()
									else
										obj:InputHoldBegin()
										task.wait(0.05)
										obj:InputHoldEnd()
									end
								end
							end)
							anySuccess = true
						end
					end
					
					if anySuccess then
						debugPrint("Successfully clicked Victim's ProximityPrompt!")
						lastVictimPromptScan = now + 1
						
						victimStillTimer = 0
						sillyJustCompleted = true
						
						if sillyActive then
							sillyActive = false
							currentSillySequence = nil
							debugPrint("Cancelled silly mode")
						end
					end
				end
			end
		end

		-- ===== SILLY BEHAVIOR WITH STUCK DETECTION (4-FIELD FORMAT) =====
		if sillyActive and currentSillySequence then
			if not sillyLastPosition then
				sillyLastPosition = rootPart.Position
				sillyStuckTimer = 0
			else
				local sillyMoved = (rootPart.Position - sillyLastPosition).Magnitude
				if sillyMoved < 0.5 then
					local data = currentSillySequence[sillyIndex]
					if data and data[4] then
						sillyStuckTimer = 0
					else
						sillyStuckTimer = sillyStuckTimer + deltaTime
					end
					if sillyStuckTimer >= 3 then
						debugPrint("[SILLY] Stuck detected! Canceling silly and forcing side-stand")
						
						sillyActive = false
						humanoid.Jump = false
						currentSillySequence = nil
						sillyLastPosition = nil
						
						inSideStand = true
						sideReached = false
						currentSide = (math.random(1, 2) == 1) and "left" or "right"
						local sidePos = getSidePosition(targetRoot, currentSide).Position
						if isSafePosition(sidePos) then
							sideTargetPosition = sidePos
						else
							local otherSide = (currentSide == "left") and "right" or "left"
							local altPos = getSidePosition(targetRoot, otherSide).Position
							sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
						end
						
						victimStillTimer = 0
						sillyJustCompleted = false
						staringActive = false
						mimicActive = false
						
						debugPrint("[SILLY] Moving to side: " .. currentSide)
						return
					end
				else
					sillyStuckTimer = 0
					sillyLastPosition = rootPart.Position
				end
			end
			
					if sillyIndex <= #currentSillySequence then
			local data = currentSillySequence[sillyIndex]

			local movePos     = targetRoot.Position + data[1]
			local victimAngle = math.atan2(-targetRoot.CFrame.LookVector.X, -targetRoot.CFrame.LookVector.Z)
			local targetAngle = data[2] + victimAngle
			local doJump      = data[3]
			local doStop      = data[4]

			local currentAngle = math.atan2(-rootPart.CFrame.LookVector.X, -rootPart.CFrame.LookVector.Z)
			local smoothAngle  = lerpAngle(currentAngle, targetAngle, deltaTime * 12)
			rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, smoothAngle, 0)

				if doStop then
					smoothMove(humanoid, rootPart.Position)
					sillyStuckTimer = 0
					sillyLastPosition = rootPart.Position
					sillyStopTimer = sillyStopTimer + deltaTime
					if sillyStopTimer >= 0.12 then
						sillyStopTimer = 0
						sillyIndex = sillyIndex + 1
					end
					return
				else
					sillyStopTimer = 0
				end

				if isSafePosition(movePos) then
					smoothMove(humanoid, movePos)
				end

				if doJump and not sillyJumped then
					debugPrint("[SILLY] Jump at index:", sillyIndex)
					humanoid.Jump = true
					sillyJumped = true
				elseif sillyJumped and humanoid.FloorMaterial ~= Enum.Material.Air then
					sillyJumped = false
				end

				local dist = (rootPart.Position - movePos).Magnitude
				local threshold = doJump and 5 or 3
				if dist < threshold then
					sillyIndex = sillyIndex + 1
				end
			else
				debugPrint("[SILLY] Completed")
				sillyActive = false
				sillyJustCompleted = true
				humanoid.Jump = false
				inSideStand = false
				currentSide = nil
				sideTargetPosition = nil
				sideReached = false
				currentSillySequence = nil
				sillyLastPosition = nil
				staringActive = false
				mimicActive = false
				debugPrint("[SILLY] Staring and mimic re-enabled")
				triggerPostSillyReaction()
			end
			return
		end

		if inSideStand and distance > EXIT_DISTANCE then
			debugPrint("[SIDE] Exiting side-stand - exceeded 8 studs, chasing instantly")
			inSideStand = false
			currentSide = nil
			sideTargetPosition = nil
			sideReached = false
			nextClickTime = 0
		end

		if not inSideStand and not victimIsMoving and distance <= ENTER_DISTANCE and victimHasMovedSinceStart then
			if not sillyActive and not actionActive and victimStillTimer < 8 and not sillyJustCompleted then
				debugPrint("[SIDE] Entering side-stand (inside 8 studs, victim stopped)")
				inSideStand = true
				holdW(false)
				setSprint(false)
				
							if not shiftIsSprint then
				local shiftLockOn = (player.DevCameraOcclusionMode == Enum.DevCameraOcclusionMode.Invisicam)
				if shiftLockOn then
					pcall(function()
						VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
						task.wait(0.05)
						VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
					end)
					debugPrint("[SHIFTLOCK] Shift Lock detected and cancelled")
				else
					debugPrint("[SHIFTLOCK] Shift Lock not active - no cancellation needed")
				end
			end
				
				sideReached = false
				currentSide = (math.random(1, 2) == 1) and "left" or "right"
				local sidePos = getSidePosition(targetRoot, currentSide).Position
				if isSafePosition(sidePos) then
					sideTargetPosition = sidePos
				else
					local otherSide = (currentSide == "left") and "right" or "left"
					local altPos = getSidePosition(targetRoot, otherSide).Position
					sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
				end
			end
		end

		if inSideStand and sideTargetPosition then
			if not sideReached then
				local distToSide = (rootPart.Position - sideTargetPosition).Magnitude
				if distToSide <= 2 then
