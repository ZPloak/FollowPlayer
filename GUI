    button.BackgroundColor3 = originalColor
end

-- ══════════════════════════════════════════════
--  Anti-void (R6 + R15 COMPATIBLE)
-- ══════════════════════════════════════════════
local CACHE_GRID = 2
local function cacheKey(pos)
	return math.floor(pos.X / CACHE_GRID) .. "," .. math.floor(pos.Y / CACHE_GRID) .. "," .. math.floor(pos.Z / CACHE_GRID)
end

local lastIgnoreListUpdate = 0
local cachedRaycastParams = nil

local function getRaycastParams()
	local now = tick()
	if not cachedRaycastParams or (now - lastIgnoreListUpdate) > 15 then
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		local ignoreList = {}
		for _, plr in ipairs(Players:GetPlayers()) do
			local char = plr.Character
			if char then
				table.insert(ignoreList, char)
				for _, child in ipairs(char:GetDescendants()) do
					if child:IsA("BasePart") then
						table.insert(ignoreList, child)
					end
				end
			end
		end
		params.FilterDescendantsInstances = ignoreList
		cachedRaycastParams = params		lastIgnoreListUpdate = now
	end
	return cachedRaycastParams
end

local function isSafePosition(pos)
	if not USE_SAFETY_RAYCAST then return true end
	if not pos then return false end
	local key = cacheKey(pos)
	local now = tick()
	local cached = safetyCache[key]
	if cached and (now - cached.t) < SAFE_RAYCAST_CACHE_TIME then
		return cached.safe
	end
	local origin = Vector3.new(pos.X, pos.Y + 3, pos.Z)
	local direction = Vector3.new(0, -(SAFE_GROUND_MAX_DROP + 3), 0)
	local result = Workspace:Raycast(origin, direction, getRaycastParams())
	local safe = result ~= nil
	safetyCache[key] = { safe = safe, t = now }
	return safe
end

local lastCachePrune = 0
local function pruneSafetyCache()
	local now = tick()
	if now - lastCachePrune < 5 then return end
	lastCachePrune = now
	for k, v in pairs(safetyCache) do
		if now - v.t > 10 then safetyCache[k] = nil end
	end
end

local function smoothMove(humanoid, targetPos)
	if not humanoid or not targetPos then return end
	pcall(function() 
		humanoid:MoveTo(targetPos) 
	end)
end

local function lerpAngle(a, b, t)
    local diff = ((b - a + math.pi) % (math.pi * 2)) - math.pi
    return a + diff * t
end

local function findPlayer(searchText)
	if searchText == "" then return nil end
	local searchLower = searchText:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			if p.Name:lower():find(searchLower, 1, true) or p.DisplayName:lower():find(searchLower, 1, true) then
				return p
			end
		end
	end
	return nil
end

local function getSidePosition(targetRoot, side)
	if side == "left" then
		return targetRoot.CFrame * CFrame.new(-SIDE_OFFSET, 0, 0)
	elseif side == "right" then
		return targetRoot.CFrame * CFrame.new(SIDE_OFFSET, 0, 0)
	end
	return targetRoot.Position
end

local function isFollowerSeated()
	local char = player.Character
	if not char then return false end
	local hum = char:FindFirstChild("Humanoid")
	return hum and (hum.Sit or hum.SeatPart ~= nil)
end

local function isVictimSeated(targetHumanoid)
	if not targetHumanoid then return false end
	return targetHumanoid.Sit or (targetHumanoid.SeatPart ~= nil)
end

