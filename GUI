	print("[SILLY] Mode:", SILLY_ENABLED and "ON" or "OFF")
	if not SILLY_ENABLED then
		sillyActive = false
		print("[SILLY] Cancelled active silly behavior")
	end
end

local function findNearestWaypointIndex(pos)
	if #recordedPositions == 0 then return 1 end
	local bestIdx = 1
	local bestDist = (pos - recordedPositions[1]).Magnitude
	for i = 2, #recordedPositions do
		local d = (pos - recordedPositions[i]).Magnitude
		if d < bestDist then
			bestDist = d
			bestIdx = i
		end
	end
	return bestIdx
end

local function pickRandomSillySequence()
	local count = #SILLY_SEQUENCES
	if count == 0 then return nil, 0 end
	local index = math.random(1, count)
	return SILLY_SEQUENCES[index], index
end

-- ══════════════════════════════════════════════
--  Main follow loop
-- ══════════════════════════════════════════════
local function startFollowing()
	if followConnection then followConnection:Disconnect() end

	local lastPathUpdate = 0
	local currentPath = nil
	local currentWaypointIndex = 0
	local lastPathTarget = nil

	victimIsMoving = false
	victimStillTimer = 0
	sillyCooldownEnd = 0
	sillyActive = false
	victimHasMovedSinceStart = false
	sillyJustCompleted = false
	inSideStand = false
	previousDistance = 0
	currentSillySequence = nil

	print("============================================")
	print("[START] Following: " .. targetPlayer.Name)
	print("[START] EXIT_DISTANCE: " .. EXIT_DISTANCE .. " studs")
	print("[START] ENTER_DISTANCE: " .. ENTER_DISTANCE .. " studs")
	print("[START] Silly sequences loaded: " .. #SILLY_SEQUENCES)
	print("============================================")

	followConnection = RunService.RenderStepped:Connect(function(deltaTime)
		pruneSafetyCache()
		checkManualMovement()

		if not isFollowing or not targetPlayer or not targetPlayer.Parent then
			if targetPlayer and not targetPlayer.Parent then
				print("[STOP] Target left")
				stopFollowing()
				Status.Text = "Target left"
			end
			return
		end

		local character = player.Character
		local targetChar = targetPlayer.Character
		if not character or not targetChar then return end

		local humanoid = character:FindFirstChild("Humanoid")
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
		if not humanoid or not rootPart or not targetRoot then return end

		local followerSeated = isSeated(humanoid)
		local targetSeated = targetHumanoid and isSeated(targetHumanoid)
		if followerSeated and not targetSeated then
			humanoid.Sit = false
			local now = tick()
			if now - lastSeatExitTime > 1.0 then
				humanoid.Jump = true
				lastSeatExitTime = now
				Status.Text = "Jumping off seat"
			end
			smoothMove(humanoid, rootPart.Position)
		end

		local distance = (targetRoot.Position - rootPart.Position).Magnitude
		local now = tick()

		if distance > EXIT_DISTANCE and previousDistance <= EXIT_DISTANCE then
			print("[RADIUS] EXITED 8 stud radius - Distance: " .. math.floor(distance) .. " studs")
		elseif distance <= ENTER_DISTANCE and previousDistance > ENTER_DISTANCE then
			print("[RADIUS] ENTERED 4 stud radius - Distance: " .. math.floor(distance) .. " studs")
		end
		previousDistance = distance

		local wasMoving = victimIsMoving
		if targetHumanoid then
			local moveDir = targetHumanoid.MoveDirection.Magnitude
			local vel = targetRoot.AssemblyLinearVelocity.Magnitude
			victimIsMoving = (moveDir > 0.5) or (vel > 2)
			if wasMoving ~= victimIsMoving then
				print("[VICTIM]", victimIsMoving and "Started moving" or "Stopped moving")
			end
			if victimIsMoving then
				victimHasMovedSinceStart = true
				sillyJustCompleted = false
			end
		else
			victimIsMoving = false
		end

		if now - lastStatusUpdate > 0.2 then
			lastStatusUpdate = now
			local mode = ""
			if recordedMode then
				if fallbackActive then mode = " [FALLBACK]"
				elseif isReplaying then mode = " [REPLAY]"
				else mode = " [REC]"
				end
			end
			local manual = manualControlActive and " [MANUAL]" or ""
			local silly = sillyActive and " [SILLY]" or ""
			Status.Text = string.format("%s%s%s%s (%.0f)", targetPlayer.DisplayName, mode, manual, silly, distance)
			Status.TextColor3 = recordedMode and Color3.fromRGB(255, 200, 100) or Color3.fromRGB(100, 200, 255)
		end

		if sillyActive and victimIsMoving then
			print("[SILLY] Cancelled - victim moved")
			sillyActive = false
			humanoid.Jump = false
			currentSillySequence = nil
		end

		if not sillyActive and not isFollowerSeated() and SILLY_ENABLED and now >= sillyCooldownEnd then
			if not victimIsMoving and distance < MAX_SILLY_DISTANCE then
				victimStillTimer = victimStillTimer + deltaTime
				if math.floor(victimStillTimer) > math.floor(victimStillTimer - deltaTime) then
					print("[TIMER] Still:", math.floor(victimStillTimer), "/", VICTIM_STILL_TIME)
				end
				if victimStillTimer >= VICTIM_STILL_TIME then
					currentSillySequence, seqIndex = pickRandomSillySequence()
					if currentSillySequence then
						print("[SILLY] TRIGGERED! Playing sequence #" .. seqIndex)
						sillyActive = true
						sillyIndex = 1
						sillyJumped = false
						victimStillTimer = 0
						sillyCooldownEnd = now + SILLY_COOLDOWN_TIME
						inSideStand = false
					else
						print("[SILLY] No sequences available!")
						victimStillTimer = 0
					end
				end
			else
				if victimStillTimer > 0.5 then
					print("[TIMER] Reset - " .. (victimIsMoving and "moved" or "too far"))
				end
				victimStillTimer = 0
			end
		else
			if victimStillTimer > 0.5 and victimIsMoving then
				print("[TIMER] Reset - moved")
			end
			victimStillTimer = 0
		end

		if sillyActive and currentSillySequence then
			if sillyIndex <= #currentSillySequence then
				local data = currentSillySequence[sillyIndex]
				local movePos = targetRoot.Position + data[1]
				if isSafePosition(movePos) then
					smoothMove(humanoid, movePos)
				end
				if data[2] and not sillyJumped then
					print("[SILLY] Jump at index:", sillyIndex)
					humanoid.Jump = true
					sillyJumped = true
				elseif sillyJumped and humanoid.FloorMaterial ~= Enum.Material.Air then
					sillyJumped = false
				end
				local dist = (rootPart.Position - movePos).Magnitude
				if dist < (data[2] and 5 or 3) then
					sillyIndex = sillyIndex + 1
				end
			else
				print("[SILLY] Completed")
				sillyActive = false
				sillyJustCompleted = true
				humanoid.Jump = false
				inSideStand = false
				currentSide = nil
				sideTargetPosition = nil
				sideReached = false
				currentSillySequence = nil
			end
			return
		end

		if inSideStand and distance > EXIT_DISTANCE then
			print("[SIDE] Exiting side-stand - exceeded 8 studs, chasing instantly")
			inSideStand = false
			currentSide = nil
			sideTargetPosition = nil
			sideReached = false
		end

		if not inSideStand and not victimIsMoving and distance <= ENTER_DISTANCE and victimHasMovedSinceStart then
			if not sillyActive and victimStillTimer < 8 and not sillyJustCompleted then
				if recordedMode then
					recordDelayEnd = nil
					isReplaying = false
					jumpTriggered = false
					resetFallbackState()
				end
				print("[SIDE] Entering side-stand (inside 4 studs, victim stopped)")
				inSideStand = true
				sideReached = false
				currentSide = (math.random(1, 2) == 1) and "left" or "right"
				local sidePos = getSidePosition(targetRoot, currentSide).Position
				if isSafePosition(sidePos) then
					sideTargetPosition = sidePos
				else
					local otherSide = (currentSide == "left") and "right" or "left"
					local altPos = getSidePosition(targetRoot, otherSide).Position
					sideTargetPosition = isSafePosition(altPos) and altPos or targetRoot.Position
				end
			end
		end

		if inSideStand and sideTargetPosition then
			if not sideReached then
				local distToSide = (rootPart.Position - sideTargetPosition).Magnitude
				if distToSide <= 2 then
					sideReached = true
					print("[SIDE] Reached side position")
				else
					smoothMove(humanoid, sideTargetPosition)
				end
			end
			return
		end

		if distance > EXIT_DISTANCE then
			if recordedMode then
				local targetMoved = lastPathTarget and (targetRoot.Position - lastPathTarget).Magnitude < 20
				if not fallbackActive and not inSideStand and targetMoved then
					recordedPositions = {}
					recordedJumpIndices = {}
					replayIndex = 1
					recordDelayEnd = tick() + RECORD_DELAY
					isReplaying = false
					jumpTriggered = false
					resetFallbackState()
				end

				if recordDelayEnd then
					if tick() >= recordDelayEnd then
						recordDelayEnd = nil
						isReplaying = true
						replayIndex = 1
						jumpTriggered = false
					else
						smoothMove(humanoid, rootPart.Position)
						return
					end
				end

				if isReplaying and not fallbackActive then
					if #recordedPositions > 0 and replayIndex <= #recordedPositions then
						local targetPos = recordedPositions[replayIndex]
						if not isSafePosition(targetPos) then
							replayIndex = replayIndex + 1
							return
						end
						smoothMove(humanoid, targetPos)

						if recordedJumpIndices[replayIndex] and not jumpTriggered then
							humanoid.Jump = true
							jumpTriggered = true
							stuckTimer = -1.0
						elseif jumpTriggered then
							if humanoid.FloorMaterial == Enum.Material.Air then
								humanoid.Jump = false
								jumpTriggered = false
								stuckTimer = 0
							end
						elseif not recordedJumpIndices[replayIndex] then
							jumpTriggered = false
						end

						local advance = false
						local distToTarget = (rootPart.Position - targetPos).Magnitude
						if recordedJumpIndices[replayIndex] then
							local horizontalDist = (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) - Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude
							if horizontalDist < REPLAY_ADVANCE_RADIUS + 3 then
								advance = true
							elseif not jumpTriggered then
								advance = true
							end
						else
							if distToTarget < REPLAY_ADVANCE_RADIUS then
								advance = true
							end
						end

						if advance then
							replayIndex = replayIndex + 1
							jumpTriggered = false
							stuckTimer = 0
						end

						if autoSwitchEnabled then
							if lastPosition then
								local moved = (rootPart.Position - lastPosition).Magnitude
								if moved < 0.5 then
									if stuckTimer >= 0 and not jumpTriggered then
										stuckTimer = stuckTimer + deltaTime
										if stuckTimer >= STUCK_TIMEOUT then
											fallbackActive = true
											fallbackPath = nil
											fallbackLastPathUpdate = 0
											fallbackLastPathTarget = nil
											fallbackWaypointIndex = 1
											stuckTimer = 0
											Status.Text = "Stuck - using pathfinding"
										end
									elseif stuckTimer < 0 then
										stuckTimer = math.min(stuckTimer + deltaTime, 0)
									end
								else
									stuckTimer = 0
									if fallbackActive then
										resetFallbackState()
									end
								end
							end
							lastPosition = rootPart.Position
						end
					else
						smoothMove(humanoid, rootPart.Position)
					end
					return
				end
			end

			if recordedMode and fallbackActive then
				if distance <= EXIT_DISTANCE then
					local nearestIdx = findNearestWaypointIndex(rootPart.Position)
					replayIndex = nearestIdx
					isReplaying = true
					resetFallbackState()
					Status.Text = "Resuming replay"
					return
				end

				if not isSafePosition(targetRoot.Position) then
					smoothMove(humanoid, rootPart.Position)
					return
				end

				if distance < DIRECT_MOVE_DISTANCE then
					if isSafePosition(targetRoot.Position) then
						smoothMove(humanoid, targetRoot.Position)
					else
						smoothMove(humanoid, rootPart.Position)
					end
					return
				end

				local needRecompute = false
				if not manualControlActive then
					if not fallbackPath then
						needRecompute = true
					elseif fallbackWaypointIndex > #fallbackPath:GetWaypoints() then
						needRecompute = true
					elseif fallbackLastPathTarget then
						local targetDrift = (targetRoot.Position - fallbackLastPathTarget).Magnitude
						if targetDrift > 5 and (now - fallbackLastPathUpdate) >= FALLBACK_PATH_UPDATE_INTERVAL then
							needRecompute = true
						end
					end
				end

				if needRecompute then
					fallbackLastPathUpdate = now
					local path = PathfindingService:CreatePath({
						AgentRadius = 2,
						AgentHeight = 5,
						AgentCanJump = true,
						AgentJumpHeight = 7.5,
						AgentMaxSlope = 45,
						WaypointSpacing = 4,
					})
					local success = pcall(function()
						path:ComputeAsync(rootPart.Position, targetRoot.Position)
					end)
					if success and path.Status == Enum.PathStatus.Success then
						local wps = path:GetWaypoints()
						local startIdx = 1
						if #wps > 1 and (rootPart.Position - wps[1].Position).Magnitude < WAYPOINT_RADIUS then
							startIdx = 2
						end
						fallbackPath = path
						fallbackWaypointIndex = startIdx
						fallbackLastPathTarget = targetRoot.Position
					else
						fallbackPath = nil
					end
				end

				if fallbackPath and not manualControlActive then
					local waypoints = fallbackPath:GetWaypoints()
					while fallbackWaypointIndex <= #waypoints do
						local wp = waypoints[fallbackWaypointIndex]
						if (rootPart.Position - wp.Position).Magnitude < WAYPOINT_RADIUS then
							fallbackWaypointIndex = fallbackWaypointIndex + 1
						else
							break
						end
					end

					if fallbackWaypointIndex <= #waypoints then
						local wp = waypoints[fallbackWaypointIndex]
						if not isSafePosition(wp.Position) then
							fallbackWaypointIndex = fallbackWaypointIndex + 1
							if fallbackWaypointIndex > #waypoints then
								fallbackPath = nil
							end
						else
							smoothMove(humanoid, wp.Position)
							if wp.Action == Enum.PathWaypointAction.Jump then
								humanoid.Jump = true
							end
						end
					else
						fallbackPath = nil
					end
				elseif not manualControlActive then
					if isSafePosition(targetRoot.Position) then
						smoothMove(humanoid, targetRoot.Position)
					else
						smoothMove(humanoid, rootPart.Position)
					end
				end
				return
			end

			if not manualControlActive then
				local recompute = false
				if not currentPath then
					recompute = true
				elseif not lastPathTarget or (targetRoot.Position - lastPathTarget).Magnitude > 5 then
					recompute = true
				elseif now - lastPathUpdate >= PATH_UPDATE_INTERVAL then
					recompute = true
				end

				if recompute then
					lastPathUpdate = now
					if isSafePosition(targetRoot.Position) then
						local path = PathfindingService:CreatePath({
							AgentRadius = 2,
							AgentHeight = 5,
							AgentCanJump = true,
							AgentJumpHeight = 7.5,
							AgentMaxSlope = 45,
							WaypointSpacing = 4,
						})
						local success = pcall(function()
							path:ComputeAsync(rootPart.Position, targetRoot.Position)
						end)
						if success and path.Status == Enum.PathStatus.Success then
							currentPath = path
							currentWaypointIndex = 1
							lastPathTarget = targetRoot.Position
						else
							currentPath = nil
						end
					else
						currentPath = nil
					end
				end

				if distance < DIRECT_MOVE_DISTANCE then
					currentPath = nil
					if isSafePosition(targetRoot.Position) then
						smoothMove(humanoid, targetRoot.Position)
					else
						smoothMove(humanoid, rootPart.Position)
					end
				elseif currentPath then
					local waypoints = currentPath:GetWaypoints()
					if currentWaypointIndex <= #waypoints then
						local waypoint = waypoints[currentWaypointIndex]
						if isSafePosition(waypoint.Position) then
							smoothMove(humanoid, waypoint.Position)
						else
							currentPath = nil
						end
						if waypoint.Action == Enum.PathWaypointAction.Jump then
							humanoid.Jump = true
						else
							humanoid.Jump = false
						end
						if (rootPart.Position - waypoint.Position).Magnitude < WAYPOINT_RADIUS then
							currentWaypointIndex = currentWaypointIndex + 1
						end
					else
						currentPath = nil
					end
				else
					if isSafePosition(targetRoot.Position) then
						smoothMove(humanoid, targetRoot.Position)
					else
						smoothMove(humanoid, rootPart.Position)
					end
				end
			end
		end
	end)
end

