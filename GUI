-- ══════════════════════════════════════════════
--  Main follow loop
-- ══════════════════════════════════════════════
local function startFollowing()
	if followConnection then followConnection:Disconnect() end

	lastPathUpdate = 0
	currentPath = nil
	currentWaypointIndex = 0
	lastPathTarget = nil

	victimIsMoving = false
	victimStillTimer = 0
	sillyCooldownEnd = 0
	sillyActive = false
	actionActive = false
	victimHasMovedSinceStart = false
	sillyJustCompleted = false
	inSideStand = false
	previousDistance = 0
	currentSillySequence = nil
	actionSequence = nil
	sillyLastPosition = nil
	sillyStuckTimer = 0
	
	shiftTested = false
	testPhase = 0
	testSamples = {}
	shiftIsSprint = true
	shiftTapDone = false

	print("============================================")
	print("[START] Following: " .. targetPlayer.Name)
	print("[START] EXIT_DISTANCE: " .. EXIT_DISTANCE .. " studs")
	print("[START] ENTER_DISTANCE: " .. ENTER_DISTANCE .. " studs")
	print("[START] Silly sequences loaded: " .. #SILLY_SEQUENCES)
	print("[START] Silly actions loaded: " .. #SILLY_ACTIONS)
	print("============================================")

	followConnection = RunService.RenderStepped:Connect(function(deltaTime)
		pruneSafetyCache()

		if not isFollowing or not targetPlayer or not targetPlayer.Parent then
			if targetPlayer and not targetPlayer.Parent then
				print("[STOP] Target left")
				stopFollowing()
				Status.Text = "Target left"
			end
			return
		end

		local character = player.Character
		local targetChar = targetPlayer.Character
		if not character or not targetChar then return end

		local humanoid = character:FindFirstChild("Humanoid")
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		local targetHumanoid = targetChar:FindFirstChild("Humanoid")
		local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
		if not humanoid or not rootPart or not targetRoot then return end

		local followerSeated = isFollowerSeated()
		local targetSeated = isVictimSeated(targetHumanoid)
		
			if followerSeated and not targetSeated then
			humanoid.Sit = false
			humanoid.Jump = true
			isInVehicle = false
			lastSeatExitTime = tick()
			debugPrint("[ANTI-SEAT] Forcing exit from seat")
			Status.Text = "Getting off seat"
		end

				-- ===== VEHICLE FOLLOW =====
		if VEHICLE_FOLLOW_ENABLED and targetSeated and not followerSeated and not isInVehicle and (tick() - lastSeatExitTime > 1) and not sillyActive and not actionActive then
			local now = tick()
			
			if now - lastVehicleScan > 2 then
				lastVehicleScan = now
				
				local nearbySeats = {}
				
				-- Search for actual Seat parts near the victim
				for _, obj in ipairs(Workspace:GetDescendants()) do
					if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
						local dist = (obj.Position - targetRoot.Position).Magnitude
						-- Check if seat is unoccupied
						local isOccupied = (obj.Occupant ~= nil)
						if dist <= 8 and not isOccupied then
							table.insert(nearbySeats, {part = obj, dist = dist, prompt = nil})
						end
					end
				end
				
				-- Also search for ProximityPrompts on seats near the victim
				for _, obj in ipairs(Workspace:GetDescendants()) do
					if obj:IsA("ProximityPrompt") then
						local parent = obj.Parent
						if parent and parent:IsA("BasePart") then
							local dist = (parent.Position - targetRoot.Position).Magnitude
							if dist <= 8 then
								local isSeat = parent:IsA("Seat") or parent:IsA("VehicleSeat") or parent.Name:lower():find("seat")
								-- Check if seat is unoccupied
								local isOccupied = parent:IsA("Seat") and parent.Occupant ~= nil
								if isSeat and obj.Enabled and not isOccupied then
									local alreadyAdded = false
									for _, s in ipairs(nearbySeats) do
										if s.part == parent then
											s.prompt = obj
											alreadyAdded = true
											break
										end
									end
									if not alreadyAdded then
										table.insert(nearbySeats, {part = parent, dist = dist, prompt = obj})
									end
								end
							end
						end
					end
				end
				
				if #nearbySeats > 0 then
					table.sort(nearbySeats, function(a, b)
						return a.dist < b.dist
					end)
					
					local closestSeat = nearbySeats[1]
					
					local delay = math.random(VEHICLE_SEAT_DELAY_MIN * 10, VEHICLE_SEAT_DELAY_MAX * 10) / 10
					debugPrint("[VEHICLE] Found seat near victim! Entering in " .. string.format("%.1f", delay) .. "s")
					task.wait(delay)
					
					if closestSeat and targetSeated and not followerSeated then
						if closestSeat.prompt then
							pcall(function()
								closestSeat.prompt:InputHoldBegin()
								task.wait(0.1)
								closestSeat.prompt:InputHoldEnd()
							end)
						else
							local seatPos = closestSeat.part.Position
							local walkTime = 0
							while walkTime < 3 do
								if not targetSeated or followerSeated then break end
								smoothMove(humanoid, seatPos)
								if (rootPart.Position - seatPos).Magnitude < 3 then
									humanoid.Sit = true
									break
								end
								task.wait(0.1)
								walkTime = walkTime + 0.1
							end
						end
						debugPrint("[VEHICLE] Entered vehicle!")
						isInVehicle = true
					end
				else
					debugPrint("[VEHICLE] Victim seated but no available seats found nearby")
				end
			end
		end

						if followerSeated and targetSeated and (tick() - closestSeatCheckTime > 1) then
			closestSeatCheckTime = tick()
			local currentSeat = humanoid.SeatPart
			if currentSeat then
				local distToVictim = (currentSeat.Position - targetRoot.Position).Magnitude
				local hasCloserSeat = false
				for _, obj in ipairs(Workspace:GetDescendants()) do
					if (obj:IsA("Seat") or obj:IsA("VehicleSeat")) and obj ~= currentSeat then
						local isOccupied = (obj.Occupant ~= nil)
						if not isOccupied then
							local d = (obj.Position - targetRoot.Position).Magnitude
							if d < distToVictim - 1 then
								hasCloserSeat = true
								break
							end
						end
					end
				end
				if hasCloserSeat then
					humanoid.Sit = false
					humanoid.Jump = true
					isInVehicle = false
					vehicleSeatPrompt = nil
					lastVehicleScan = 0
					debugPrint("[VEHICLE] Closer seat found - jumping off to switch")
				end
			end
		end

		if not targetSeated and isInVehicle then
			isInVehicle = false
			vehicleSeatPrompt = nil
			debugPrint("[VEHICLE] Victim exited vehicle")
		end

		local distance = (targetRoot.Position - rootPart.Position).Magnitude
		local now = tick()

		if distance > EXIT_DISTANCE and previousDistance <= EXIT_DISTANCE then
			debugPrint("[RADIUS] EXITED 8 stud radius - Distance: " .. math.floor(distance) .. " studs")
		elseif distance <= ENTER_DISTANCE and previousDistance > ENTER_DISTANCE then
			debugPrint("[RADIUS] ENTERED 8 stud radius - Distance: " .. math.floor(distance) .. " studs")
		end
		previousDistance = distance
		
		updateSprintTest(character)

		-- ===== CAMERA TRACKING =====
		if CAMERA_ENABLED and targetRoot and not actionActive then
			local camera = workspace.CurrentCamera
			if camera then
				local mouseDelta = UserInputService:GetMouseDelta()
				local isManualCamera = (math.abs(mouseDelta.X) > 0 or math.abs(mouseDelta.Y) > 0)
				
				if isManualCamera then
					lastManualCameraTime = now
				end
				
				if distance > CAMERA_TRACK_MIN and distance <= CAMERA_TRACK_MAX then
					if lastManualCameraTime and (now - lastManualCameraTime) >= 0.5 then
						local lookAtPos = targetRoot.Position + Vector3.new(0, 2, 0)
						local newCFrame = CFrame.lookAt(camera.CFrame.Position, lookAtPos)
						camera.CFrame = camera.CFrame:Lerp(newCFrame, CAMERA_SMOOTHNESS)
					end
				end
			end
		end

		-- ===== STARING CONTEST + MIMIC + SILLY ACTIONS =====
		if targetRoot and rootPart then
			local distanceToVictim = (targetRoot.Position - rootPart.Position).Magnitude
			
			if distanceToVictim > 16 or not SILLY_ENABLED then
				staringActive = false
				mimicActive = false
				if not actionActive then
					-- Don't cancel action if it's playing
				end
				sillyTimerPaused = false
			else
				local viewBlocked = isVictimViewBlocked(targetRoot, rootPart)
				local victimLooking = isVictimLookingAtFollower(targetRoot, targetHumanoid, rootPart) and not viewBlocked
				local now = tick()
				local camera = workspace.CurrentCamera
				
				-- ===== VICTIM LOOKING AT FOLLOWER =====
				if victimLooking then
					lastVictimLookTime = now
					mimicActive = false
					mimicScheduledTime = 0
					
					if not actionActive then
						actionCooldown = false
					end
					
					if not staringActive and not stareDelayStart and not actionActive then
						stareDelayStart = now
						stareTimer = 0
						debugPrint("[STARE] Victim looking! Waiting 0.5s...")
					elseif staringActive and not actionActive then
						stareEndTime = now + 0.5
					end
				else
					if staringActive and not actionActive then
						if now >= stareEndTime then
							staringActive = false
							stareDelayStart = nil
							stareTimer = 0
							sillyTimerPaused = false
							debugPrint("[STARE] Victim looked away - scheduling mimic in 1s")
							mimicScheduledTime = now + 1.0
						end
					elseif stareDelayStart and not actionActive then
						stareDelayStart = nil
						debugPrint("[STARE] Victim looked away during delay")
					end
				end
				
				-- ===== ACTIVATE STARING =====
				if stareDelayStart and not staringActive and not actionActive then
					if now - stareDelayStart >= 0.5 then
						staringActive = true
						stareEndTime = now + 0.5
						stareDelayStart = nil
						stareTimer = 0
						sillyTimerPaused = true
						debugPrint("[STARE] Now staring at victim!")
					end
				end
				
				-- ===== ACTIVATE MIMIC =====
				if mimicScheduledTime > 0 and now >= mimicScheduledTime and now < mimicScheduledTime + 1.0 and not actionActive then
					if not mimicActive then
						mimicActive = true
						mimicScheduledTime = 0
						debugPrint("[MIMIC] Activated - facing victim's direction!")
					end
				end
				
				-- ===== STARE TIMER → TRIGGER SILLY ACTION (NO 5s COOLDOWN) =====
				if staringActive and not actionActive and not actionCooldown then
					stareTimer = stareTimer + deltaTime
					
					if math.floor(stareTimer) > math.floor(stareTimer - deltaTime) then
						debugPrint("[STARE TIMER] " .. math.floor(stareTimer) .. " / 10 seconds")
					end
					
					if stareTimer >= 10 then
						-- Pick a random silly action
						local chosenAction, actionIdx = pickRandomSillyAction()
						if chosenAction then
							-- Check if it's FriendlyJump (string) or a sequence (table)
							if chosenAction == "FriendlyJump" then
								-- Just jump 1-3 times
								actionActive = true
								actionSequence = nil
								staringActive = false
								mimicActive = false
								sillyTimerPaused = true
								inSideStand = false
								debugPrint("[ACTION] Triggered: Friendly Jump!")
								
								local jumps = math.random(1, 3)
								for i = 1, jumps do
									if not actionActive then break end
									humanoid.Jump = true
									task.wait(0.4)
								end
								
								actionActive = false
								actionCooldown = true
								staringActive = false
								mimicActive = false
								sillyTimerPaused = false
								inSideStand = true
								stareTimer = 0
								debugPrint("[ACTION] Friendly Jump completed!")
								triggerPostSillyReaction()
							else
								-- It's a sequence (KissMV or HeadpatMV)
								actionActive = true
								actionSequence = chosenAction
								actionIndex = 1
								actionJumped = false
								actionStopTimer = 0
								actionStuckTimer = 0
								actionLastPosition = nil
								staringActive = false
								mimicActive = false
								sillyTimerPaused = true
								inSideStand = false
								stareTimer = 0
								local actionName = SILLY_ACTION_NAMES[actionIdx] or ("Action #" .. actionIdx)
								debugPrint("[ACTION] Triggered: " .. actionName)
							end
						end
					end
				end
				
				-- ===== PAUSE SILLY TIMER WHEN STARE/ACTION ACTIVE =====
				if sillyTimerPaused or staringActive or actionActive then
					victimStillTimer = 0
				end
				
				-- ===== PLAY SILLY ACTION SEQUENCE (KissMV / HeadpatMV) =====
				if actionActive and actionSequence then
					if not actionLastPosition then
						actionLastPosition = rootPart.Position
						actionStuckTimer = 0
					else
						local actionMoved = (rootPart.Position - actionLastPosition).Magnitude
						if actionMoved < 0.5 then
							local data = actionSequence[actionIndex]
							if data and data[4] then
								actionStuckTimer = 0
							else
								actionStuckTimer = actionStuckTimer + deltaTime
							end
							if actionStuckTimer >= 3 then
								debugPrint("[ACTION] Stuck detected! Canceling action")
								actionActive = false
								actionSequence = nil
								sillyTimerPaused = false
								staringActive = false
								mimicActive = false
								inSideStand = true
								sideReached = false
								currentSide = (math.random(1, 2) == 1) and "left" or "right"
								local sidePos = getSidePosition(targetRoot, currentSide).Position
								sideTargetPosition = isSafePosition(sidePos) and sidePos or targetRoot.Position
								return
							end
						else
							actionStuckTimer = 0
							actionLastPosition = rootPart.Position
						end
					end
					
					if actionIndex <= #actionSequence then
						local data = actionSequence[actionIndex]
						local movePos = targetRoot.Position + data[1]
						local victimAngle = math.atan2(-targetRoot.CFrame.LookVector.X, -targetRoot.CFrame.LookVector.Z)
						local targetAngle = data[2] + victimAngle
						local doJump = data[3]
						local doStop = data[4]
						
						-- Smoothly rotate to the recorded angle
						local currentAngle = math.atan2(-rootPart.CFrame.LookVector.X, -rootPart.CFrame.LookVector.Z)
						local smoothAngle = lerpAngle(currentAngle, targetAngle, deltaTime * 12)
						rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, smoothAngle, 0)
						
						-- Handle stopped frames
						if doStop then
							smoothMove(humanoid, rootPart.Position)
							actionStuckTimer = 0
							actionLastPosition = rootPart.Position
							actionStopTimer = actionStopTimer + deltaTime
							if actionStopTimer >= 0.12 then
								actionStopTimer = 0
								actionIndex = actionIndex + 1
							end
							return
						else
							actionStopTimer = 0
						end
						
						-- Move toward the waypoint
						if isSafePosition(movePos) then
							smoothMove(humanoid, movePos)
						end
						
						-- Jump handling
						if doJump and not actionJumped then
							debugPrint("[ACTION] Jump at index:", actionIndex)
							humanoid.Jump = true
							actionJumped = true
						elseif actionJumped and humanoid.FloorMaterial ~= Enum.Material.Air then
							actionJumped = false
						end
						
						-- Check if we reached the waypoint
						local dist = (rootPart.Position - movePos).Magnitude
						local threshold = doJump and 5 or 3
						if dist < threshold then
							actionIndex = actionIndex + 1
						end
					else
						-- Action sequence complete
						debugPrint("[ACTION] Silly action completed!")
						actionActive = false
						actionSequence = nil
						actionCooldown = true
						sillyTimerPaused = false
						staringActive = false
						mimicActive = false
						inSideStand = true
						debugPrint("[ACTION] Staring and mimic re-enabled, side-stand restored")
						triggerPostSillyReaction()
					end
					return
				end
				
					-- ===== PRIORITY 2: MIMIC =====
					if mimicActive and not actionActive and not followerSeated then
					local victimLookDir = targetRoot.CFrame.LookVector
					
					-- Raycast from victim in the direction they're looking (up to 10 studs)
					local rayParams = RaycastParams.new()
					rayParams.FilterType = Enum.RaycastFilterType.Exclude
					rayParams.FilterDescendantsInstances = {targetRoot.Parent, player.Character}
					local rayResult = Workspace:Raycast(targetRoot.Position, victimLookDir * 10, rayParams)
					
					local mimicTarget

					if rayResult then
    				mimicTarget = rayResult.Position
    				if not mimicLastBlockedObject or mimicLastBlockedObject ~= rayResult.Instance.Name then
        			mimicLastBlockedObject = rayResult.Instance.Name
        			debugPrint("[MIMIC] View blocked - looking at object: " .. rayResult.Instance.Name)
    			end
			else
    				mimicTarget = targetRoot.Position + victimLookDir * 10
    				mimicLastBlockedObject = nil
				end

					local flatTarget = Vector3.new(mimicTarget.X, rootPart.Position.Y, mimicTarget.Z)
					if (flatTarget - rootPart.Position).Magnitude > 0.1 then
						local targetCFrame = CFrame.lookAt(rootPart.Position, flatTarget)
						rootPart.CFrame = rootPart.CFrame:Lerp(targetCFrame, 0.12)
						
						if camera then
							local newCFrame = CFrame.lookAt(camera.CFrame.Position, mimicTarget)
							camera.CFrame = camera.CFrame:Lerp(newCFrame, 0.1)
						end
					end
					
					if now - lastVictimLookTime > 2.0 then
						mimicActive = false
						debugPrint("[MIMIC] Ended after 2 seconds")
					end
					
					return
				end

				-- ===== POST-SILLY REACTION =====
				if postSillyReaction and not actionActive and not mimicActive and not staringActive then
					postSillyReactionTimer = postSillyReactionTimer + deltaTime
					
					local delayTime = 0.5 + (postSillyReactionChance * 0.5)
					if postSillyReactionChance == 0 then
						postSillyReactionChance = math.random()
						delayTime = 0.5 + (postSillyReactionChance * 0.5)
						debugPrint("[POST-SILLY] Delay: " .. string.format("%.2f", delayTime) .. "s")
					end
					
					if postSillyReactionTimer >= delayTime then
						if postSillyReactionType == "stare" then
							staringActive = true
							stareEndTime = now + 2.0
							debugPrint("[POST-SILLY] Now staring at victim for 2s")
						elseif postSillyReactionType == "mimic" then
							mimicActive = true
							lastVictimLookTime = now
							debugPrint("[POST-SILLY] Now mimicking victim for 2s")
						end
						
						postSillyReaction = false
						postSillyReactionChance = 0
						postSillyReactionTimer = 0
						postSillyReactionType = ""
					end
					
					return
				end
				
					-- ===== PRIORITY 3: STARING =====
					if staringActive and not actionActive and not followerSeated then
					if camera then
						local lookAtPos = targetRoot.Position + Vector3.new(0, 2, 0)
						local newCFrame = CFrame.lookAt(camera.CFrame.Position, lookAtPos)
						camera.CFrame = camera.CFrame:Lerp(newCFrame, 0.08)
					end
					
					local flatDir = Vector3.new(targetRoot.Position.X - rootPart.Position.X, 0, targetRoot.Position.Z - rootPart.Position.Z)
					if flatDir.Magnitude > 0.1 then
						local targetCFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + flatDir.Unit)
						rootPart.CFrame = rootPart.CFrame:Lerp(targetCFrame, 0.15)
					end
				end
			end
		end

		-- ===== NEW SIMPLE SOCIAL: Step aside when blocked =====
		if NEW_SOCIAL_ENABLED and not isMovingAside and not sillyActive and not actionActive then
			local now = tick()
			local victimLooking = isVictimLookingAtFollower(targetRoot, targetHumanoid, rootPart)
			
			if victimLooking then
				stareLingerUntil = now + 4.0
			end
			
			local isActive = victimLooking or (stareLingerUntil and now < stareLingerUntil)
			
			if isActive and (now - lastBlockerCheck > 0.3) then
				lastBlockerCheck = now
				
				local isBlocked, blocker = isSomeoneBlocking(rootPart, targetRoot)
				
				if isBlocked and blocker then
					local blockerName = blocker.DisplayName
					
					stareLingerUntil = now + 4.0
					
					if blockerName == lastBlockerName then
						blockCount = blockCount + 1
					else
						lastBlockerName = blockerName
						blockCount = 1
					end
					
					debugPrint("[SOCIAL] " .. blockerName .. " is blocking! Waiting 2s... (Count: " .. blockCount .. ")")
					
					isMovingAside = true
					
					task.wait(2.0)
					
					if not targetRoot or not rootPart then
						isMovingAside = false
						return
					end
					
					local stillBlocked, _ = isSomeoneBlocking(rootPart, targetRoot)
					if not stillBlocked then
						debugPrint("[SOCIAL] Blocker left during delay, cancelling")
						isMovingAside = false
						return
					end
					
					if blockCount >= PERSISTENT_BLOCK_THRESHOLD then
						debugPrint("[SOCIAL] Persistent blocker! Moving to victim's side using side-stand")
						
