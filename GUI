					debugPrint("[SIDE] Reached side position")
				else
					smoothMove(humanoid, sideTargetPosition)
				end
			end
			
			if sideReached and RANDOM_CLICK_ENABLED and SILLY_ENABLED then
				local now = tick()
				
				if now - lastClickableScan > 3 then
					clickablesCache = scanClickables(rootPart.Position)
					lastClickableScan = now
					if #clickablesCache > 0 then
						if SILLY_ENABLED then
							debugPrint("[CLICK] Found " .. #clickablesCache .. " clickables nearby")
						end
					else
						if SILLY_ENABLED then
							debugPrint("[CLICK] No clickables found within " .. CLICK_SEARCH_RADIUS .. " studs")
						end
					end
				end
				
				if nextClickTime == 0 and #clickablesCache > 0 then
					local delay = math.random(MIN_CLICK_DELAY * 10, MAX_CLICK_DELAY * 10) / 10
					nextClickTime = now + delay
					if SILLY_ENABLED then
						debugPrint("[CLICK] Next click in " .. string.format("%.1f", delay) .. "s")
					end
				end
				
				if nextClickTime > 0 and now >= nextClickTime and #clickablesCache > 0 then
					local clickSuccess = clickRandomObject()
					
					clickablesCache = {}
					nextClickTime = 0
					
					if clickSuccess then
						if sillyActive then
							sillyActive = false
							currentSillySequence = nil
							if SILLY_ENABLED then
								debugPrint("[CLICK] Cancelled silly mode due to click")
							end
						end
						
						victimStillTimer = 0
						sillyJustCompleted = true
						if SILLY_ENABLED then
							debugPrint("[CLICK] Disabled silly mode until victim moves away")
						end
					else
						if SILLY_ENABLED then
							debugPrint("[CLICK] Click failed, will try again later")
						end
					end
				end
			end
			
			return
		else
			if nextClickTime ~= 0 then
				nextClickTime = 0
				if SILLY_ENABLED then
					debugPrint("[CLICK] Reset timer - left side-stand")
				end
			end
		end

		-- ===== CHASE WHEN OUTSIDE 8 STUDS =====
		if distance > EXIT_DISTANCE then
			if not isSafePosition(targetRoot.Position) then
				holdW(false)
				setSprint(false)
				debugPrint("[ANTI-VOID] Target position unsafe - holding position")
				return
			end

			holdW(true)
			
			if distance >= SPRINT_DISTANCE and not shiftTested and testPhase == 0 and victimHasMovedSinceStart then
				testSprintBehavior(character)
			end
			
			if distance >= SPRINT_DISTANCE and shiftTested and shiftIsSprint then
				setSprint(true)
			elseif distance <= 10 then
				setSprint(false)
			end
			
			if distance < DIRECT_MOVE_DISTANCE then
				if isSafePosition(targetRoot.Position) then
					smoothMove(humanoid, targetRoot.Position)
				else
					smoothMove(humanoid, rootPart.Position)
				end
				currentPath = nil
				return
			end

			local needRecompute = false
			if not currentPath then
				needRecompute = true
			elseif lastPathTarget then
				local targetDrift = (targetRoot.Position - lastPathTarget).Magnitude
				if targetDrift > 50 then
					needRecompute = true
					debugPrint("[PATH] Recomputing - target moved " .. math.floor(targetDrift) .. " studs")
				elseif currentWaypointIndex > #currentPath:GetWaypoints() then
					if distance > DIRECT_MOVE_DISTANCE and (rootPart.Position - targetRoot.Position).Magnitude > 10 then
						needRecompute = true
						debugPrint("[PATH] Recomputing - reached end of path but still far")
					end
				end
			end
			
			if needRecompute and (now - lastPathUpdate) < 2.0 then
				needRecompute = false
			end
			
			if needRecompute and (now - lastPathUpdate) < 0.5 then
				needRecompute = false
			end

			if needRecompute then
				debugPrint("[PATH] Computing initial path")
				lastPathUpdate = now
				if isSafePosition(targetRoot.Position) then
					local path = PathfindingService:CreatePath({
						AgentRadius = 2,
						AgentHeight = 5,
						AgentCanJump = true,
						AgentJumpHeight = 7.5,
						AgentMaxSlope = 45,
						WaypointSpacing = 4,
					})
					local success = pcall(function()
						path:ComputeAsync(rootPart.Position, targetRoot.Position)
					end)
					if success and path.Status == Enum.PathStatus.Success then
						currentPath = path
						currentWaypointIndex = 1
						lastPathTarget = targetRoot.Position
						debugPrint("[PATH] Path computed successfully with " .. #path:GetWaypoints() .. " waypoints")
					else
						currentPath = nil
						debugPrint("[PATH] Path computation failed")
					end
				else
					currentPath = nil
				end
			end

			if currentPath then
				local waypoints = currentPath:GetWaypoints()
				
				while currentWaypointIndex <= #waypoints do
					local wp = waypoints[currentWaypointIndex]
					if (rootPart.Position - wp.Position).Magnitude < WAYPOINT_RADIUS then
						currentWaypointIndex = currentWaypointIndex + 1
					else
						break
					end
				end
				
				if currentWaypointIndex <= #waypoints then
					local waypoint = waypoints[currentWaypointIndex]
					if isSafePosition(waypoint.Position) then
						smoothMove(humanoid, waypoint.Position)
						if waypoint.Action == Enum.PathWaypointAction.Jump then
							humanoid.Jump = true
						end
					else
						currentWaypointIndex = currentWaypointIndex + 1
					end
				else
					if distance > DIRECT_MOVE_DISTANCE then
						currentPath = nil
					end
				end
			else
				if isSafePosition(targetRoot.Position) then
					smoothMove(humanoid, targetRoot.Position)
				else
					smoothMove(humanoid, rootPart.Position)
				end
			end
		end
		
		if distance <= W_RELEASE_DISTANCE then
			if not isSprinting then
				holdW(false)
			end
			pcall(function()
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
			end)
		end
	end)
end

